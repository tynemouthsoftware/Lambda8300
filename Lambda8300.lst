0816   035D             ; GET_REGION
0817   035D 3E FF           ld a,0ffh               ; Read port $7E
0818   035F DB 7E           in a,(07eh)             ; Will return the same as $FE unless there is something different in the Lambda
0819   0361 1F              rra                     ; Bit 7 => carry (Bit 7 that is the tape input???)
0820   0362 3F              ccf                     ; carry = !carry
0821   0363 9F              sbc a,a                 ; A = $FF (PAL) or $00 (NTSC)
0822   0364 E6 18           and 018h                ; A = $18       or $00
0823   0366 C6 1F           add a,01fh              ; A = $37       or $1F
0824   0368 32 28 40        ld (04028h),a           ; Save this as MARGIN
0825   036B C9              ret
