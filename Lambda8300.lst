4152   1116             
4153   1116             ; PAUSE-3
4154   1116             l1116h:
4155   1116 78              ld a,b                  ; A = bit 7 of B
4156   1117 E6 80           and 080h
4157   1119 57              ld d,a                  ; D = old bit 7 of B
4158   111A CB F8           set 7,b                 ; Set bit 7, indicatin PAUSE mode
4159   111C ED 43 34 40     ld (04034h),bc          ; Alternate value in frame counter
4160   1120             
4161   1120             ; PAUSE-4
4162   1120             l1120h:
4163   1120 ED 4B 34 40     ld bc,(04034h)          ; Get frame counter
4164   1124 CB B8           res 7,b                 ; ignore bit 7
4165   1126 78              ld a,b                  ; check if MSB
4166   1127 B1              or c                    ; LSB
4167   1128 B2              or d                    ; and old bit 7 are all zero (i.e. we have waited long enough)
4168   1129 28 E5           jr z,l1110h             ; finished, back to PAUSE-2
4169   112B 7E              ld a,(hl)               ; get CDFLAG
4170   112C 1F              rra                     ; test bit 7 for fast mode
4171   112D 38 E1           jr c,l1110h             ; finished, back to PAUSE-2
4172   112F 18 EF           jr l1120h               ; loop back to PAUSE-4
