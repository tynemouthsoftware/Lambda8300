0598   0281             ; --------------------------
0599   0281             ; THE 'SLOW' COMMAND ROUTINE
0600   0281             ; --------------------------
0601   0281             
0602   0281             ; SLOW
0603   0281             sub_0281h:
0604   0281 FD CB 3B F6     set 6,(iy+03bh)         ; Request slow mode ()
0605   0285             
0606   0285             ; FAST/SLOW
0607   0285             sub_0285h:
0608   0285 21 3B 40        ld hl,0403bh            ; load the CDFLAG
0609   0288 7E              ld a,(hl)
0610   0289 17              rla                     ; bit 6 (request) -> bit 7 (current state)
0611   028A AE              xor (hl)                ; XOR with actual current state
0612   028B 17              rla                     ; result -> carry
0613   028C D0              ret nc                  ; return if already in requested mode
0614   028D             
0615   028D CB FE           set 7,(hl)              ; set slow mode - compute and display
0616   028F F5              push af
0617   0290 C5              push bc
0618   0291 D5              push de
0619   0292 E5              push hl
0620   0293             
0621   0293             ; Called where DISPLAY-1 usually was
0622   0293             ; PRE-DISPLAY-1
0623   0293             sub_0293h:
0624   0293 AF              xor a                   ; clear the line counter
0625   0294 08              ex af,af'
0626   0295 D3 FE           out (0feh),a            ; enable NMI generator
0627   0297 76              halt                    ; wait for interrupt
0628   0298 D3 FD           out (0fdh),a            ; disable NMI generator
0629   029A 7E              ld a,(hl)               ; waste cycles
0630   029B 7E              ld a,(hl)
0631   029C 00              nop
0632   029D             
0633   029D             ; -----------------------
0634   029D             ; THE 'MAIN DISPLAY' LOOP
0635   029D             ; -----------------------
0636   029D             ; This routine is executed once for every frame displayed.
0637   029D             
0638   029D             ;; DISPLAY-1
0639   029D             l029dh:
0640   029D 2A 34 40        ld hl,(04034h)          ; Get the frame count from FRAMES
0641   02A0 2B              dec hl
0642   02A1 3E 7F           ld a,07fh               ; Mask bit 7
0643   02A3 A4              and h                   ; of H
0644   02A4 B5              or l                    ; and OR with L
0645   02A5 7C              ld a,h                  ;
0646   02A6 20 03           jr nz,l02abh            ; Jump if frame counter bits 0-14 are zero
0647   02A8 17              rla                     ; bit 15 of frame counter (1 if paused) to carry
0648   02A9 18 02           jr l02adh               ; skip
0649   02AB             
0650   02AB             ; ANOTHER
0651   02AB             l02abh:
0652   02AB 46              ld b,(hl)               ; Dummy timing
0653   02AC 37              scf                     ; set carry
0654   02AD             
0655   02AD             ; OVER-NC
0656   02AD             l02adh:
0657   02AD 67              ld h,a
0658   02AE 22 34 40        ld (04034h),hl          ; Save the new frame count to FRAMES
0659   02B1 D0              ret nc                  ; Return if FRAMES is in use by PAUSE command
0660   02B2             
0661   02B2             ; ZX81 goes string to ; DISPLAY-2
0662   02B2             
0663   02B2             ; Bit 7 of the cursor character is inverted every 16 frames
0664   02B2             ; That makes it flashe approximately 2 times a second
0665   02B2             ; BLINK-CURSOR
0666   02B2 7D              ld a,l                  ; A = LSB of FRAMES
0667   02B3 2A 7B 40        ld hl,(0407bh)          ; Address of blinking cursor
0668   02B6 CB 26           sla (hl)                ; rotate cursor character
0669   02B8 17              rla                     ;
0670   02B9 17              rla                     ;
0671   02BA 17              rla                     ;
0672   02BB 17              rla                     ; rotate A bit 4 into carry
0673   02BC CB 1E           rr (hl)                 ; rotate carry back into character
0674   02BE             
0675   02BE             ; DISPLAY-2
0676   02BE CD 3D 03        call sub_033dh          ; KEYBOARD - scan keyboard and start VSYNC
0677   02C1 ED 4B 25 40     ld bc,(04025h)          ; get LAST_K
0678   02C5 22 25 40        ld (04025h),hl          ; update LAST_K
0679   02C8 78              ld a,b
0680   02C9 C6 02           add a,002h
0681   02CB ED 42           sbc hl,bc
0682   02CD 3A 27 40        ld a,(04027h)           ; Check DEBOUNCE
0683   02D0 B4              or h
0684   02D1 B5              or l
0685   02D2 58              ld e,b
0686   02D3 06 09           ld b,009h               ; ZX81 used $0B
0687   02D5 21 3B 40        ld hl,0403bh            ; Get CDFLAG
0688   02D8 CB 86           res 0,(hl)
0689   02DA 20 08           jr nz,l02e4h
0690   02DC CB 7E           bit 7,(hl)
0691   02DE CB C6           set 0,(hl)
0692   02E0 C8              ret z                   ; return if in FAST mode
0693   02E1 05              dec b
0694   02E2 05              dec b                   ; extra DEC B, ZX81 was NOP
0695   02E3 37              scf
0696   02E4             
0697   02E4             ; NO-KEY
0698   02E4             l02e4h:
0699   02E4 CB 10           rl b                    ; Reordered from ZX81
0700   02E6             
0701   02E6             ; LOOP-B
0702   02E6             l02e6h:
0703   02E6 10 FE           djnz l02e6h
0704   02E8 21 27 40        ld hl,04027h
0705   02EB 46              ld b,(hl)               ; Get DEBOUCE
0706   02EC 7B              ld a,e
0707   02ED FE FE           cp 0feh
0708   02EF 9F              sbc a,a
0709   02F0 06 0F           ld b,00fh               ; ZX81 has $1F
0710   02F2 B6              or (hl)
0711   02F3 A0              and b
0712   02F4 1F              rra
0713   02F5 77              ld (hl),a
0714   02F6             l02f6h:
0715   02F6 29              add hl,hl
0716   02F7 23              inc hl
0717   02F8 D3 FF           out (0ffh),a            ; End VSYNC pulse
0718   02FA             
