0945   03D7 18 FB           jr l03d4h
0946   03D9             
0947   03D9             ; ------------------------
0948   03D9             ; THE 'IN-BYTE' SUBROUTINE
0949   03D9             ; ------------------------
0950   03D9             
0951   03D9             ; IN-BYTE
0952   03D9             sub_03d9h:
0953   03D9 0E 01           ld c,001h
0954   03DB             
0955   03DB             ; NEXT-BIT
0956   03DB             l03dbh:
0957   03DB 06 00           ld b,000h
0958   03DD             
0959   03DD             ; BREAK-3
0960   03DD             l03ddh:
0961   03DD 3E 7F           ld a,07fh
0962   03DF DB FE           in a,(0feh)
0963   03E1 D3 FF           out (0ffh),a
0964   03E3 1F              rra
0965   03E4 30 49           jr nc,l042fh
0966   03E6 17              rla
0967   03E7 17              rla
0968   03E8 38 28           jr c,l0412h
0969   03EA 10 F1           djnz l03ddh
0970   03EC F1              pop af
0971   03ED BA              cp d
0972   03EE             
0973   03EE             ; RESTART
0974   03EE             l03eeh:
0975   03EE D2 A3 04        jp nc,l04a3h
0976   03F1 62              ld h,d
0977   03F2 6B              ld l,e
0978   03F3             
0979   03F3             ; IN-NAME
0980   03F3             l03f3h:
0981   03F3 CD D9 03        call sub_03d9h
0982   03F6 CB 7A           bit 7,d
0983   03F8 79              ld a,c
0984   03F9 20 03           jr nz,l03feh
0985   03FB BE              cp (hl)
0986   03FC 20 D6           jr nz,l03d4h
0987   03FE             
0988   03FE             ; MATCHING
0989   03FE             l03feh:
0990   03FE 23              inc hl
0991   03FF 17              rla
0992   0400 30 F1           jr nc,l03f3h
0993   0402 FD 34 15        inc (iy+015h)
0994   0405 21 09 40        ld hl,04009h
0995   0408             
0996   0408             ; IN-PROG
0997   0408             l0408h:
0998   0408 50              ld d,b
0999   0409 CD D9 03        call sub_03d9h
1000   040C 71              ld (hl),c
1001   040D CD 16 02        call sub_0216h
1002   0410 18 F6           jr l0408h
1003   0412             
1004   0412             ; GET-BIT
1005   0412             l0412h:
1006   0412 D5              push de
1007   0413 1E 94           ld e,094h
1008   0415             
1009   0415             ; TRAILER
1010   0415             l0415h:
1011   0415 06 1A           ld b,01ah
1012   0417             
1013   0417             ; COUNTER
1014   0417             l0417h:
1015   0417 1D              dec e
1016   0418 DB FE           in a,(0feh)
1017   041A 17              rla
1018   041B CB 7B           bit 7,e
1019   041D 7B              ld a,e
1020   041E 38 F5           jr c,l0415h
1021   0420 10 F5           djnz l0417h
1022   0422 D1              pop de
1023   0423 20 04           jr nz,l0429h
1024   0425 FE 56           cp 056h
1025   0427 30 B2           jr nc,l03dbh
1026   0429             
1027   0429             ; BIT-DONE
1028   0429             l0429h:
1029   0429 3F              ccf
1030   042A CB 11           rl c
1031   042C 30 AD           jr nc,l03dbh
1032   042E C9              ret
1033   042F             
1034   042F             ; BREAK-4
1035   042F             l042fh:
1036   042F 7A              ld a,d
1037   0430 A7              and a
1038   0431 28 BB           jr z,l03eeh
1039   0433             
1040   0433             ; REPORT-D
1041   0433             l0433h:
1042   0433 CF              rst 08h                 ; ERROR-1
1043   0434 0C              .byte $0C               ; Error Report: BREAK - CONT repeats
1044   0435             
1045   0435             ; -----------------------------
1046   0435             ; THE 'PROGRAM NAME' SUBROUTINE
1047   0435             ; -----------------------------
1048   0435             
1049   0435             ; NAME
1050   0435             sub_0435h:
1051   0435 CD 4A 11        call sub_114ah          ; routine SCANNING
1052   0438 3A 01 40        ld a,(04001h)
1053   043B 87              add a,a
1054   043C FA 17 0F        jp m,l0f17h             ; to REPORT-C - Invalid Expression
1055   043F E1              pop hl
1056   0440 D0              ret nc
1057   0441 E5              push hl
1058   0442 CD 70 03        call sub_0370h          ; routine SET-FAST
1059   0445 CD ED 15        call sub_15edh          ; routine STK-FETCH
1060   0448 62              ld h,d
1061   0449 6B              ld l,e
1062   044A 0D              dec c
1063   044B F8              ret m
1064   044C 09              add hl,bc
1065   044D CB FE           set 7,(hl)
1066   044F C9              ret
1067   0450             
1068   0450             ; --------------------------
1069   0450             ; THE 'MAKE A NOISE' ROUTINE
1070   0450             ; --------------------------
1071   0450             
1072   0450             ; MAKE-NOISE
1073   0450             sub_0450h:
1074   0450 1E 20           ld e,020h               ; note = 32500/32 = 1.02KHz
1075   0452 01 00 18        ld bc,01800h            ; duration = 6144/65 = 94ms
1076   0455 18 09           jr l0460h               ; Routine PLAY-NOTE
1077   0457             
1078   0457             ; ----------------------------
1079   0457             ; THE 'SOUND' COMMAND ROUTINE
1080   0457             ; ----------------------------
1081   0457             
1082   0457             ; SOUND
1083   0457             sub_0457h:
1084   0457 CD 88 10        call sub_1088h          ; routine FIND-INT => BC
1085   045A C5              push bc
1086   045B CD 83 10        call sub_1083h          ; routine FIND-SHORT => A
1087   045E C1              pop bc
1088   045F 5F              ld e,a                  ; INT => E
1089   0460             
1090   0460             ; PLAY-NOTE
1091   0460             ; E = note, defined as 32500Hz/E, so (0=256=>127Hz) to (1=>32.5KHz)
1092   0460             ; BC = duration, defined as BC/65ms, so (1=>15ms) to (0=65536=>1 second)
1093   0460             ; Appox 4 times slower in SLOW mode
1094   0460             l0460h:
1095   0460 DB F5           in a,(0f5h)             ; Toggle beeper on read of $F5
1096   0462 53              ld d,e                  ; Note
1097   0463             ; PLAY-NOTE-2
1098   0463             l0463h:
1099   0463 0B              dec bc                  ; Duration
1100   0464 78              ld a,b
1101   0465 B1              or c
1102   0466 C8              ret z                   ; Return when BC=0
1103   0467 15              dec d
1104   0468 28 F6           jr z,l0460h             ; Toggle speaker when note countdown complete
1105   046A 00              nop
1106   046B 00              nop
1107   046C 18 F5           jr l0463h               ; Loop until complete
1108   046E             
1109   046E             
1110   046E             ; ---------------
1111   046E             ; START CONTINUED
1112   046E             ; ---------------
1113   046E             
1114   046E             ; START-3
1115   046E             l046eh:
1116   046E 1F              rra                     ; A was read from FE, column 0 -> C
1117   046F 2F              cpl
1118   0470 32 06 40        ld (04006h),a           ; set mode
1119   0473 01 FF BF        ld bc,0bfffh            ; top of possible RAM, making max RAM 32K
1120   0476 30 11           jr nc,l0489h            ; skip RAM test if key in column 0 held? autostart expansion ROM?
1121   0478 3A 7D 40        ld a,(0407dh)           ; check of there is a DFILE
1122   047B FE 76           cp 076h                 ; should start with a NL/HALT
1123   047D 20 0A           jr nz,l0489h            ; no DFILE, so do a cold start
1124   047F 28 3F           jr z,l04c0h             ; DFILE present, warm start, skip RAM test
1125   0481             
1126   0481             ; -------------------------
1127   0481             ; THE 'NEW' COMMAND ROUTINE
1128   0481             ; -------------------------
1129   0481             
1130   0481             ; NEW
1131   0481             sub_0481h:
1132   0481 CD 70 03        call sub_0370h          ; Set FAST mode
1133   0484 ED 4B 04 40     ld bc,(04004h)          ; RAMTOP top of detected / protected RAM
1134   0488 0B              dec bc
1135   0489             
1136   0489             ; RAM check
1137   0489             l0489h:
1138   0489 60              ld h,b                  ; HL = BC = last byte to test
1139   048A 69              ld l,c
1140   048B 3E 3F           ld a,03fh               ; stop point, check RAM down to $4000
1141   048D             
1142   048D             ; RAM fill
1143   048D             l048dh:
1144   048D 36 02           ld (hl),002h            ; write 2 to every address in RAM.
1145   048F 2B              dec hl
1146   0490 BC              cp h                    ; stop when H=A=$3F
1147   0491 20 FA           jr nz,l048dh
1148   0493             
1149   0493             ; RAM read
1150   0493             l0493h:
1151   0493 A7              and a                   ; reset carry flag
1152   0494 ED 42           sbc hl,bc               ; Compare HL and BC
1153   0496 09              add hl,bc               ;
1154   0497 23              inc hl                  ; HL = 4000 - what was the point in all that?
1155   0498 30 06           jr nc,l04a0h            ; if HL=BC, we're finished?
1156   049A 35              dec (hl)                ; Decrement RAM
1157   049B 28 03           jr z,l04a0h             ; Test if RAM was 1, but it would be picked up by the next test anyway?
1158   049D                                         ; I wonder if this was original a test for mirrors? but it doesn't do that now
1159   049D 35              dec (hl)                ; Decrement RAM
1160   049E 28 F3           jr z,l0493h             ; It was 2 previously, zero now, good RAM, keep checking
1161   04A0             
1162   04A0             ; Set TOP
1163   04A0             l04a0h:
1164   04A0 22 04 40        ld (04004h),hl          ; Set RAMTOP, top of usable RAM
1165   04A3             l04a3h:
1166   04A3 21 97 43        ld hl,04397h            ; Set VARS, starts of variable area
1167   04A6 22 10 40        ld (04010h),hl          ; VARS = $4397 - fixed location after DFILE
1168   04A9 2B              dec hl                  ; HL = 4396, start of program
1169   04AA 36 FF           ld (hl),0ffh
1170   04AC             l04ach:
1171   04AC 22 0C 40        ld (0400ch),hl          ; Set PRGRM
1172   04AF             
1173   04AF             ; Create expanded DFILE
1174   04AF 0E 19           ld c,019h               ; 24 lines + 1 extra NL
1175   04B1 AF              xor a                   ; A = 0 = Space
1176   04B2             
1177   04B2             ; Next line
1178   04B2             l04b2h:
1179   04B2 2B              dec hl
1180   04B3 36 76           ld (hl),076h            ; start / end with newline / halt
1181   04B5 0D              dec c                   ; line counter
1182   04B6 28 08           jr z,l04c0h             ; finished?
1183   04B8             
1184   04B8             ; Fill line
1185   04B8 06 20           ld b,020h               ; fill line with 32 spaces
1186   04BA             l04bah:
1187   04BA 2B              dec hl                  ; step backwards
1188   04BB 77              ld (hl),a               ; write a space
1189   04BC 10 FC           djnz l04bah             ; loop until done
1190   04BE 18 F2           jr l04b2h               ; back for more
1191   04C0             
1192   04C0             ; Set system variables
1193   04C0             l04c0h:
1194   04C0 2A 04 40        ld hl,(04004h)          ; RAMTOP
1195   04C3 2B              dec hl                  ; last system byte
1196   04C4 36 3E           ld (hl),03eh            ; end marker
1197   04C6 2B              dec hl
1198   04C7 F9              ld sp,hl                ; stack here
1199   04C8 2B              dec hl
1200   04C9 2B              dec hl
1201   04CA 22 02 40        ld (04002h),hl          ; ERR_SP, address of top of GOSUB stack
1202   04CD ED 56           im 1                    ; Z80 interrupt mode 1
1203   04CF FD 21 00 40     ld iy,04000h            ; start of SYS VARS
1204   04D3 FD 36 3B 40     ld (iy+03bh),040h       ; CDFLAG - compute and display mode requested
1205   04D7 FD 36 21 19     ld (iy+021h),019h       ; SPARE1 = $40?
1206   04DB AF              xor a
1207   04DC 32 19 40        ld (04019h),a           ; X_PTR_lo = 0
1208   04DF 32 2D 40        ld (0402dh),a           ; FLAGX = 0
1209   04E2 32 01 40        ld (04001h),a           ; FLAGS = 0
1210   04E5 32 7C 40        ld (0407ch),a           ; SPARE3 = 0
1211   04E8 3D              dec a
1212   04E9 32 35 40        ld (04035h),a           ; FRAMES_lo = $FF
1213   04EC             l04ech:
1214   04EC CD 92 16        call sub_1692h          ; CLEAR
1215   04EF CD 50 04        call sub_0450h          ; MAKE-NOISE
1216   04F2 CD 85 02        call sub_0285h          ; SLOW-FAST to set SLOW mode
1217   04F5 3A 06 40        ld a,(04006h)           ; check mode
1218   04F8 1F              rra
1219   04F9 DA 00 20        jp c,02000h             ; autostart expansion ROM?
1220   04FC             
1221   04FC             l04fch:
1222   04FC CD A5 16        call sub_16a5h          ; CURSOR-IN, set cursor on edit line
1223   04FF             
1224   04FF             ; ---------------------------
1225   04FF             ; THE 'BASIC LISTING' SECTION
1226   04FF             ; ---------------------------
1227   04FF             
1228   04FF             ; UPPER
1229   04FF             l04ffh:
1230   04FF CD D0 0B        call sub_0bd0h          ; CLS
1231   0502 2A 29 40        ld hl,(04029h)          ; E.PPC line number with cursor on (was $400A on ZX81)
1232   0505 ED 5B 23 40     ld de,(04023h)
1233   0509 A7              and a
1234   050A ED 52           sbc hl,de
1235   050C EB              ex de,hl
1236   050D 30 04           jr nc,l0513h
1237   050F 19              add hl,de
1238   0510 22 23 40        ld (04023h),hl
1239   0513             
1240   0513             ; ADDR-TOP
1241   0513             l0513h:
1242   0513 CD 6A 0B        call sub_0b6ah
1243   0516 28 01           jr z,l0519h
1244   0518 EB              ex de,hl
1245   0519             
1246   0519             ; LIST-TOP
1247   0519             l0519h:
1248   0519 CD CD 08        call sub_08cdh
1249   051C FD 35 1E        dec (iy+01eh)
1250   051F 20 37           jr nz,l0558h            ; routine LOWER
1251   0521 2A 29 40        ld hl,(04029h)          ; E.PPC line number with cursor on (was $400A on ZX81)
1252   0524 CD 6A 0B        call sub_0b6ah
1253   0527 2A 16 40        ld hl,(04016h)
1254   052A 37              scf
1255   052B ED 52           sbc hl,de
1256   052D 21 23 40        ld hl,04023h
1257   0530 30 0B           jr nc,l053dh
1258   0532 EB              ex de,hl
1259   0533 7E              ld a,(hl)
1260   0534 23              inc hl
1261   0535 ED A0           ldi
1262   0537 12              ld (de),a
1263   0538 18 C5           jr l04ffh
1264   053A             
1265   053A             ; DOWN-KEY
1266   053A             sub_053ah:
1267   053A 21 29 40        ld hl,04029h            ; E.PPC line number with cursor on (was $400A on ZX81)
1268   053D             
1269   053D             ; INC-LINE
1270   053D             l053dh:
1271   053D 5E              ld e,(hl)
1272   053E 23              inc hl
1273   053F 56              ld d,(hl)
1274   0540 E5              push hl
1275   0541 EB              ex de,hl
1276   0542 23              inc hl
1277   0543 CD 6A 0B        call sub_0b6ah
1278   0546 CD 77 06        call sub_0677h
1279   0549 E1              pop hl
1280   054A             
1281   054A             ; KEY-INPUT
1282   054A             l054ah:
1283   054A FD CB 2D 6E     bit 5,(iy+02dh)
1284   054E 20 08           jr nz,l0558h            ; routine LOWER
1285   0550 72              ld (hl),d
1286   0551 2B              dec hl
1287   0552 73              ld (hl),e
1288   0553 18 AA           jr l04ffh
1289   0555             
1290   0555             ; ----------------------------
1291   0555             ; THE 'EDIT LINE COPY' SECTION
1292   0555             ; ----------------------------
1293   0555             
1294   0555             ; EDIT-INP
1295   0555             l0555h:
1296   0555 CD A5 16        call sub_16a5h          ; CURSOR-IN, set cursor on edit line
1297   0558             
1298   0558             ; LOWER
1299   0558             l0558h:
1300   0558 2A 14 40        ld hl,(04014h)
1301   055B             
1302   055B             ; EACH-CHAR
1303   055B             l055bh:
1304   055B 7E              ld a,(hl)
1305   055C FE 7E           cp 07eh
1306   055E 20 08           jr nz,l0568h
1307   0560 01 06 00        ld bc,l0006h
1308   0563 CD F5 0B        call sub_0bf5h          ; routine RECLAIM-2
1309   0566 18 F3           jr l055bh
1310   0568             
1311   0568             ; END-LINE
1312   0568             l0568h:
1313   0568 FE 76           cp 076h
1314   056A 23              inc hl
1315   056B 20 EE           jr nz,l055bh
1316   056D             
1317   056D             ; EDIT-LINE
1318   056D                 ; ZX81 sets K or L here - we don't have that
1319   056D             
1320   056D             ; EDIT-ROOM
1321   056D             l056dh:
1322   056D CD C2 0B        call sub_0bc2h          ; routine LINE-ENDS
1323   0570 2A 14 40        ld hl,(04014h)          ; Get E.LINE, the address of edit line
1324   0573 FD 36 00 FF     ld (iy+000h),0ffh       ; Set error to $FF (OK)
1325   0577 CD FC 08        call sub_08fch          ; routine COPY-LINE
1326   057A FD CB 00 7E     bit 7,(iy+000h)         ; Check if there was an error
1327   057E 20 0D           jr nz,l058dh            ; to DISPLAY-6 if OK
1328   0580 3A 22 40        ld a,(04022h)           ; check DF.SZ, size of editor section
1329   0583 FE 18           cp 018h                 ; is it >24 lines
1330   0585 30 06           jr nc,l058dh            ; to DISPLAY-6
1331   0587 3C              inc a                   ; add a line
1332   0588 32 22 40        ld (04022h),a           ; update value
1333   058B 18 E0           jr l056dh               ; simplified loop back compared to ZX81
1334   058D             
1335   058D             ; --------------------------
1336   058D             ; THE 'WAIT FOR KEY' SECTION
1337   058D             ; --------------------------
1338   058D             
1339   058D             ; DISPLAY-6
1340   058D             l058dh:
1341   058D 21 00 00        ld hl,l0000h            ; clear X.PTR   - Addess of character before syntax error
1342   0590 22 18 40        ld (04018h),hl          ;
1343   0593 21 3B 40        ld hl,0403bh            ; get CDFLAGS
1344   0596 CB 7E           bit 7,(hl)              ; check FAST/SLOW mode
1345   0598 CC 93 02        call z,sub_0293h        ; routine PRE-DISPLAY-1 if FAST
1346   059B             
1347   059B             ; SLOW-DISP
1348   059B             l059bh:
1349   059B CB 46           bit 0,(hl)
1350   059D 28 FC           jr z,l059bh             ; Loop unti bit 0 of (HL) is 1
1351   059F ED 4B 25 40     ld bc,(04025h)
1352   05A3 CD 40 11        call sub_1140h          ; routine DEBOUNCE
1353   05A6 CD 5E 09        call sub_095eh          ; routine DECODE
1354   05A9 30 AD           jr nc,l0558h            ; routine LOWER
1355   05AB FD CB 3B 6E     bit 5,(iy+03bh)         ; Check if we should beep
1356   05AF 20 1D           jr nz,l05ceh
1357   05B1             
1358   05B1             ; KEY-BEEP
1359   05B1 D5              push de                 ; Save DE and HL
1360   05B2 E5              push hl
1361   05B3 CD 70 03        call sub_0370h          ; routine SET-FAST
1362   05B6 C6 14           add a,014h              ; add $14 to the key value
1363   05B8 5F              ld e,a                  ; set the note to that
1364   05B9 01 CE 04        ld bc,004ceh            ; set the duration to 18.9ms
1365   05BC FD CB 28 6E     bit 5,(iy+028h)         ; test bit 5 of MARGIN to check region
1366   05C0 20 03           jr nz,l05c5h            ; skip if PAL
1367   05C2 01 06 04        ld bc,00406h            ; change duration to 15.9ms
1368   05C5             l05c5h:
1369   05C5 CD 60 04        call l0460h             ; Routine PLAY-NOTE
1370   05C8 CD 85 02        call sub_0285h          ; FAST/SLOW
1371   05CB E1              pop hl                  ; restore DE and HL
1372   05CC D1              pop de
1373   05CD 7B              ld a,e                  ; and A is restored to what it was + $14 (is that intentional?)
1374   05CE             
1375   05CE             ; variation on FETCH-2
1376   05CE             l05ceh:
1377   05CE FD CB 01 56     bit 2,(iy+001h)         ; Check FLAG K mode = 0, L = 1
1378   05D2 28 08           jr z,l05dch             ; skip for K mode
1379   05D4 FE 28           cp 028h                 ; check for ?
1380   05D6 38 1A           jr c,l05f2h             ; skip
1381   05D8 21 A1 00        ld hl,000a1h
1382   05DB 19              add hl,de
1383   05DC             
1384   05DC             ; FETCH-3
1385   05DC             l05dch:
1386   05DC 7E              ld a,(hl)
1387   05DD             
1388   05DD             ; TEST-CURS
1389   05DD             l05ddh:
1390   05DD FE F0           cp 0f0h
1391   05DF EA FB 05        jp pe,l05fbh            ; routine KEY-SORT
1392   05E2             
1393   05E2             ; ENTER
1394   05E2 5F              ld e,a
1395   05E3 CD 05 06        call sub_0605h          ; routine CURSOR
1396   05E6 7B              ld a,e
1397   05E7 CD ED 05        call sub_05edh          ; routine ADD-CHAR
1398   05EA             
1399   05EA             ; BACK-NEXT
1400   05EA             l05eah:
1401   05EA C3 58 05        jp l0558h               ; back to LOWER
1402   05ED             
1403   05ED             ; ------------------------------
1404   05ED             ; THE 'ADD CHARACTER' SUBROUTINE
1405   05ED             ; ------------------------------
1406   05ED             
1407   05ED             ; ADD-CHAR
1408   05ED             sub_05edh:
1409   05ED CD 2D 0B        call sub_0b2dh
1410   05F0 12              ld (de),a
1411   05F1 C9              ret
1412   05F2             
1413   05F2             ; more variation on FETCH-2
1414   05F2             l05f2h:
1415   05F2 7E              ld a,(hl)
1416   05F3 FE 76           cp 076h                 ; check for NEWLINE
1417   05F5 CB FF           set 7,a
1418   05F7 20 E4           jr nz,l05ddh            ; routine TEST-CURS
1419   05F9 3E 78           ld a,078h
1420   05FB             
1421   05FB             ; KEY-SORT
1422   05FB             l05fbh:
