0802   034B FE 01           cp 001h
0803   034D 9F              sbc a,a
0804   034E B0              or b
0805   034F A5              and l
0806   0350 6F              ld l,a
0807   0351 7C              ld a,h
0808   0352 A2              and d
0809   0353 67              ld h,a
0810   0354 CB 00           rlc b
0811   0356 ED 78           in a,(c)
0812   0358 38 ED           jr c,l0347h
0813   035A 1F              rra
0814   035B CB 14           rl h
