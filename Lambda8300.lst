0436   0119 38 2C B3        .byte   $38,$2C,$33+$80                 ; SGN
0437   011C 26 27 B8        .byte   $26,$27,$38+$80                 ; ABS
0438   011F 35 2A 2A B0     .byte   $35,$2A,$2A,$30+$80             ; PEEK
0439   0123 3A 38 B7        .byte   $3A,$38,$37+$80                 ; USR
0440   0126 38 39 37 8D     .byte   $38,$39,$37,$0D+$80             ; STR$
0441   012A 28 2D 37 8D     .byte   $28,$2D,$37,$0D+$80             ; CHR$
0442   012E 33 34 B9        .byte   $33,$34,$39+$80                 ; NOT
