0001   0000             ; Disassembly of the Lambda 8300 ROM
0002   0000             ; Dave Curran 2026-06-12
0003   0000             
0004   0000             ; Where functions are identical to ZX81, only the function names are commented
0005   0000             ; Refer to the ZX81 assembly listing by Geoff Wearmouth for further comments
0006   0000             ; https://web.archive.org/web/20111004151617/http://www.wearmouth.demon.co.uk/zx81.htm
0007   0000             
0008   0000             ; assemble with TASM
0009   0000             ; TASM.EXE -t80 -fff -b Lambda8300.asm Lambda8300.bin
0010   0000             
0011   0000             ; Z80 @ 3.25MHz
0012   0000             ; 8K of ROM
0013   0000             ; 2K of RAM
0014   0000             ; expandable to 32k of RAM
0015   0000             
0016   0000             ; Memory Map
0017   0000             ; $0000-1FFF        - ROM
0018   0000             ; $2000-3FFF        - Option ROM
0019   0000             ; $4000     ERR.NR  - Current report code -1
0020   0000             ; $4001     FLAGS   - Some flags
0021   0000             ; $4002/03  ERR.SP  - Address of top of GOSUB stack
0022   0000             ; $4004/05  RAMTOP  - Address of reserved area
0023   0000             ; $4006     MODE    - Cursor mode
0024   0000             ; $4007/08  PPC     - Line number being executed
0025   0000             ; $4009     VERSN   - Version = 0
0026   0000             ; $400A/0B  NXTLIN  - Address of next line to be executed (ZX81 has E.PPC here)
0027   0000             ; $400C/0D  PRGRM   - Start of user program = $4396 (ZX81 has DFILE here)
0028   0000             ; $400E/0F  DF.CC   - Display file current character
0029   0000             ; $4010/11  VARS    - Start of variable area
0030   0000             ; $4012/13  DEST    - Address of variable being assigned
0031   0000             ; $4014/15  E.LINE  - Address of edit line
0032   0000             ; $4016/17  CH.ADD  - Next character to interpret
0033   0000             ; $4018/19  X.PTR   - Addess of character before syntax error
0034   0000             ; $401A/1B  STKBOT  - Address of calculator stack
0035   0000             ; $401C/1D  STKEND  - End of calculator stack
0036   0000             ; $401E     BREG    - Floating point B register
0037   0000             ; $401F/20  MEM     - Address of calc memory area = MEMBOT
0038   0000             ; $4021     TEMPO   - Setting of music tempo (was SPARE1)
0039   0000             ; $4022     DF.SZ   - Size of editor part of screen
0040   0000             ; $4023/24  S.TOP   - Line number at top of screen
0041   0000             ; $4025/26  LAST.K  - Last keyboard scan
0042   0000             ; $4027     DB.ST   - Keyboard debounce status
0043   0000             ; $4028     MARGIN  - Number of lines in margin
0044   0000             ; $4029/2A  E.PPC   - Line number of line with cursor (ZX81 has NXTLIN here)
0045   0000             ; $402B/2C  OLDPPC  - Address of line where CONT jumps
0046   0000             ; $402D     FLAGX   - Some more flags
0047   0000             ; $402E/F   STRLEN  - String length
0048   0000             ; $4030/31  T.ADDR  - Next item in syntax table
0049   0000             ; $4032/33  SEED    - Seed for RND
0050   0000             ; $4034/35  FRAMES  - Frame counter
0051   0000             ; $4035/37  COORDS  - Last point plotted (to add for DRAW?)
0052   0000             ; $4038     PR.CC   - Address of LPRINT position
0053   0000             ; $4039/3A  S.POSN  - Current PRINT position
0054   0000             ; $403B     CDFLAG  - Compute Display Flags for FAST/SLOW mode (Bit 7 = 1 for SLOW, Bit 6 = 1 to request SLOW mode)
0055   0000             ; $403C-5C  PRBUFF  - Printer buffer
0056   0000             ; $405D-7A  MEMBOT  - Calculator memory
0057   0000             ; $407B-7C  BLINK   - Cursor blink
0058   0000             ; $407D-$4395       - Display file
0059   0000             ; $4396-RAMTOP      - User Program memory
0060   0000             
0061   0000             ; no DFILE - Location of display file, that is hard coded at $407D
0062   0000             
0063   0000             .org    00000h
0064   0000             
0065   0000             ; -----------
0066   0000             ; THE 'START'
0067   0000             ; -----------
0068   0000             
0069   0000             ; START
0070   0000             l0000h:
0071   0000 D3 FD           out (0fdh),a            ; turn off NMI
0072   0002             l0002h:
0073   0002 3E BF           ld a,0bfh
0074   0004 DB FE           in a,(0feh)             ; keyboard read (hold down key for ROM at $2000?)
0075   0006             l0006h:
0076   0006 18 1D           jr l0025h               ; Jump to START-3 via START-2
0077   0008             
0078   0008             ; -------------------
0079   0008             ; THE 'ERROR' RESTART
0080   0008             ; -------------------
0081   0008             
0082   0008             ; ERROR-1
0083   0008             l0008h:
0084   0008 2A 16 40        ld hl,(04016h)          ; CH.ADD - Address of next character to interpret
0085   000B 22 18 40        ld (04018h),hl          ; X.PTR - Address of character before error
0086   000E 18 47           jr l0057h               ;
0087   0010             
0088   0010             ; -------------------------------
0089   0010             ; THE 'PRINT A CHARACTER' RESTART
0090   0010             ; -------------------------------
0091   0010             
0092   0010             ; PRINT-A
0093   0010             l0010h:
0094   0010 A7              and a
0095   0011             l0011h:
0096   0011 C2 92 09        jp nz,l0992h
0097   0014 C3 96 09        jp l0996h
0098   0017             
0099   0017 FF              .byte $FF               ; unused
0100   0018             
0101   0018             ; ---------------------------------
0102   0018             ; THE 'COLLECT A CHARACTER' RESTART
0103   0018             ; ---------------------------------
0104   0018             
0105   0018             ; GET-CHAR
0106   0018             l0018h:
0107   0018 2A 16 40        ld hl,(04016h)
0108   001B 7E              ld a,(hl)
0109   001C             l001ch:
0110   001C A7              and a
0111   001D C0              ret nz
0112   001E 00              nop
0113   001F 00              nop
0114   0020             
0115   0020             ; ------------------------------------
0116   0020             ; THE 'COLLECT NEXT CHARACTER' RESTART
0117   0020             ; ------------------------------------
0118   0020             
0119   0020             ; NEXT-CHAR
0120   0020             l0020h:
0121   0020 CD 4A 00        call sub_004ah
0122   0023 18 F7           jr l001ch
0123   0025             
0124   0025             ; start continued
0125   0025             
0126   0025             ; START-2
0127   0025             l0025h:
0128   0025 C3 6E 04        jp l046eh
0129   0028             
0130   0028             ; ---------------------------------------
0131   0028             ; THE 'FLOATING POINT CALCULATOR' RESTART
0132   0028             ; ---------------------------------------
0133   0028             
0134   0028             ; FP-CALC
0135   0028             l0028h:
0136   0028 C3 94 1B        jp l1b94h
0137   002B             
0138   002B             ; end-calc
0139   002B             sub_002bh:
0140   002B F1              pop af
0141   002C D9              exx
0142   002D E3              ex (sp),hl
0143   002E D9              exx
0144   002F C9              ret
0145   0030             
0146   0030             ; -----------------------------
0147   0030             ; THE 'MAKE BC SPACES'  RESTART
0148   0030             ; -----------------------------
0149   0030             
0150   0030             ; BC-SPACES
0151   0030             l0030h:
0152   0030 C5              push bc
0153   0031 2A 14 40        ld hl,(04014h)
0154   0034 E5              push hl
0155   0035 C3 7D 16        jp l167dh
0156   0038             
0157   0038             ; -----------------------
0158   0038             ; THE 'INTERRUPT' RESTART
0159   0038             ; -----------------------
0160   0038             
0161   0038             ; INTERRUPT
0162   0038             l0038h:
0163   0038 0D              dec c
0164   0039 20 0A           jr nz,l0045h
0165   003B E1              pop hl
0166   003C 05              dec b
0167   003D C8              ret z
0168   003E C8              ret z                   ; extra delay? not in ZX81
0169   003F 0E 08           ld c,008h               ; faster than SET 3,C (but is that a good thing here?)
0170   0041             
0171   0041             ; WAIT-INT
0172   0041             l0041h:
0173   0041 ED 4F           ld r,a
0174   0043 FB              ei
0175   0044 E9              jp (hl)                 ; jump into display file mirror
0176   0045             
0177   0045             ; SCAN-LINE
0178   0045             l0045h:
0179   0045 D1              pop de
0180   0046 00              nop                     ; different timing to ZX81
0181   0047 18 F8           jr l0041h
0182   0049             
0183   0049 00              .byte $00               ; unused (which moved $004A-$0065 1 byte away from ZX81)
0184   004A             
0185   004A             ; ---------------------------------
0186   004A             ; THE 'INCREMENT CH-ADD' SUBROUTINE
0187   004A             ; ---------------------------------
0188   004A             
0189   004A             ; CH-ADD+1
0190   004A             sub_004ah:
0191   004A 2A 16 40        ld hl,(04016h)
0192   004D             
0193   004D             ; TEMP-PTR1
0194   004D             l004dh:
0195   004D 23              inc hl
0196   004E             
0197   004E             ; TEMP-PTR2
0198   004E             sub_004eh:
0199   004E 22 16 40        ld (04016h),hl
0200   0051 7E              ld a,(hl)
0201   0052 FE 7F           cp 07fh
0202   0054 C0              ret nz
0203   0055 18 F6           jr l004dh
0204   0057             
0205   0057             ; --------------------
0206   0057             ; THE 'ERROR-2' BRANCH
0207   0057             ; --------------------
0208   0057             
0209   0057             ; ERROR-2
0210   0057             l0057h:
0211   0057 E1              pop hl                  ; get error code
0212   0058 6E              ld l,(hl)               ; extract error byte
0213   0059             
0214   0059             ; ERROR-3
0215   0059             l0059h:
0216   0059 FD 75 00        ld (iy+000h),l          ; set ERR_NR, system error number
0217   005C ED 7B 02 40     ld sp,(04002h)          ; reset stack pointer to top of GOSUB stack
0218   0060 CD 85 02        call sub_0285h          ; SLOW mode
0219   0063 C3 B4 16        jp l16b4h               ; exit via SET_MIN to clear calculator stack
0220   0066             
0221   0066             ; ------------------------------------
0222   0066             ; THE 'NON MASKABLE INTERRUPT' ROUTINE
0223   0066             ; ------------------------------------
0224   0066             
0225   0066             ; NMI
0226   0066             l0066h:
0227   0066 08              ex af,af'               ; NMI uses the alternate A&F
0228   0067 3C              inc a                   ; Incrememnt line count
0229   0068 CA 6E 00        jp z,l006eh             ; Jump if line count has reached 0
0230   006B 00              nop                     ; NMI test removed (ROM will not run on ZX80 hardware)
0231   006C             
0232   006C             ; NMI-RET
0233   006C 08              ex af,af'               ; Return to normal A&F
0234   006D C9              ret                     ; Return to user code
0235   006E             
0236   006E             ; NMI-CONT
0237   006E             l006eh:
0238   006E 08              ex af,af'               ; Return to normal A&F
0239   006F F5              push af                 ; Save the main registers
0240   0070 C5              push bc                 ;
0241   0071 D5              push de                 ;
0242   0072 E5              push hl                 ;
0243   0073 21 7D C0        ld hl,$407D + $8000     ; Set HL to fixed DFILE mirror location (not ($400C) with bit 7 set)
0244   0076 76              halt                    ; sync with NMI
0245   0077             
0246   0077 D3 FD           out (0fdh),a            ; stop the NMI generator
0247   0079 DD E9           jp (ix)                 ; forward to X (after top) or X
0248   007B             
0249   007B             
0250   007B             ; ****************
0251   007B             ; ** KEY TABLES **
0252   007B             ; ****************
0253   007B             
0254   007B             ; -------------------------------
0255   007B             ; THE 'UNSHIFTED' CHARACTER CODES
0256   007B             ; -------------------------------
0257   007B             
0258   007B             ; K-UNSHIFT
0259   007B             L007bh:
0260   007B             
0261   007B 3F              .byte    $3F            ; Z
0262   007C 3D              .byte    $3D            ; X
0263   007D 28              .byte    $28            ; C
0264   007E 3B              .byte    $3B            ; V
0265   007F             
0266   007F 26              .byte    $26            ; A
0267   0080 38              .byte    $38            ; S
0268   0081 29              .byte    $29            ; D
0269   0082 2B              .byte    $2B            ; F
0270   0083 2C              .byte    $2C            ; G
0271   0084             
0272   0084 36              .byte    $36            ; Q
0273   0085 3C              .byte    $3C            ; W
0274   0086 2A              .byte    $2A            ; E
0275   0087 37              .byte    $37            ; R
0276   0088 39              .byte    $39            ; T
0277   0089             
0278   0089 1D              .byte    $1D            ; 1
0279   008A 1E              .byte    $1E            ; 2
0280   008B 1F              .byte    $1F            ; 3
0281   008C 20              .byte    $20            ; 4
0282   008D 21              .byte    $21            ; 5
0283   008E             
0284   008E 1C              .byte    $1C            ; 0
0285   008F 25              .byte    $25            ; 9
0286   0090 24              .byte    $24            ; 8
0287   0091 23              .byte    $23            ; 7
0288   0092 22              .byte    $22            ; 6
0289   0093 35              .byte    $35            ; P
0290   0094             
0291   0094 34              .byte    $34            ; O
0292   0095 2E              .byte    $2E            ; I
0293   0096 3A              .byte    $3A            ; U
0294   0097 3E              .byte    $3E            ; Y
0295   0098 76              .byte    $76            ; NEWLINE
0296   0099             
0297   0099 31              .byte    $31            ; L
0298   009A 30              .byte    $30            ; K
0299   009B 2F              .byte    $2F            ; J
0300   009C 2D              .byte    $2D            ; H
0301   009D 00              .byte    $00            ; SPACE
0302   009E             
0303   009E 1B              .byte    $1B            ; .
0304   009F 32              .byte    $32            ; M
0305   00A0 33              .byte    $33            ; N
0306   00A1 27              .byte    $27            ; B
0307   00A2             
0308   00A2             ; -----------------------------
0309   00A2             ; THE 'SHIFTED' CHARACTER CODES
0310   00A2             ; -----------------------------
0311   00A2             
0312   00A2             ; K-SHIFT
0313   00A2             l00a2h:
0314   00A2 F5              .byte    $F5            ; Shift + Z = PRINT
0315   00A3 7A              .byte    $7A            ; Shift + X = Line no
0316   00A4 70              .byte    $70            ; Shift + C = cursor-up
0317   00A5 71              .byte    $71            ; Shift + V = cursor-down
0318   00A6             
0319   00A6 C6              .byte    $C6            ; Shift + A = ASN
0320   00A7 C7              .byte    $C7            ; Shift + S = ACS
0321   00A8 C8              .byte    $C8            ; Shift + D = ATN
0322   00A9 CA              .byte    $CA            ; Shift + F = EXP
0323   00AA CE              .byte    $CE            ; Shift + G = ABS
0324   00AB             
0325   00AB C3              .byte    $C3            ; Shift + Q = SIN
0326   00AC C4              .byte    $C4            ; Shift + W = COS
0327   00AD C5              .byte    $C5            ; Shift + E = TAN
0328   00AE C9              .byte    $C9            ; Shift + R = LOG
0329   00AF CD              .byte    $CD            ; Shift + T = SGN
0330   00B0             
0331   00B0 0F              .byte    $0F            ; Shift + 1 = ?
0332   00B1 0C              .byte    $0C            ; Shift + 2 = £
0333   00B2 0E              .byte    $0E            ; Shift + 3 = :
0334   00B3 0D              .byte    $0D            ; Shift + 4 = $
0335   00B4 0B              .byte    $0B            ; Shift + 5 = "
0336   00B5             
0337   00B5 14              .byte    $14            ; Shift + 0 = =
0338   00B6 11              .byte    $11            ; Shift + 9 = )
0339   00B7 10              .byte    $10            ; Shift + 8 = (
0340   00B8 1A              .byte    $1A            ; Shift + 7 = ,
0341   00B9 19              .byte    $19            ; Shift + 6 = ;
0342   00BA             
0343   00BA 12              .byte    $12            ; Shift + P = >
0344   00BB 13              .byte    $13            ; Shift + O = <
0345   00BC 45              .byte    $45            ; Shift + I = PI
0346   00BD 43              .byte    $43            ; Shift + U = RND
0347   00BE CC              .byte    $CC            ; Shift + Y = SQR
0348   00BF             
0349   00BF 74              .byte    $74            ; Shift + N/L = GRAPHICS
0350   00C0 15              .byte    $15            ; Shift + L = +
0351   00C1 16              .byte    $16            ; Shift + K = -
0352   00C2 17              .byte    $17            ; Shift + J = *
0353   00C3 18              .byte    $18            ; Shift + H = /
0354   00C4             
0355   00C4 79              .byte    $79            ; Shift + SPACE = FUNCTION
0356   00C5 77              .byte    $77            ; Shift + . = RUBOUT
0357   00C6 75              .byte    $75            ; Shift + M = EDIT
0358   00C7 73              .byte    $73            ; Shift + N = cursor-right
0359   00C8 72              .byte    $72            ; Shift + B = cursor-left
0360   00C9             
0361   00C9             
0362   00C9             ; -----------------------------
0363   00C9             ; THE 'GRAPHIC' CHARACTER CODES
0364   00C9             ; -----------------------------
0365   00C9             
0366   00C9             ; K-GRAPH
0367   00C9             ; 00c9
0368   00C9 83              .byte    $83            ; Graphics + Z = graphic
0369   00CA 03              .byte    $03            ; Graphics + X = graphic
0370   00CB 05              .byte    $05            ; Graphics + C = graphic
0371   00CC 85              .byte    $85            ; Graphics + V = graphic
0372   00CD             
0373   00CD 08              .byte    $08            ; Graphics + A = graphic
0374   00CE 0A              .byte    $0A            ; Graphics + S = graphic
0375   00CF 09              .byte    $09            ; Graphics + D = graphic
0376   00D0 8A              .byte    $8A            ; Graphics + F = graphic
0377   00D1 89              .byte    $89            ; Graphics + G = graphic
0378   00D2             
0379   00D2 01              .byte    $01            ; Graphics + Q = graphic
0380   00D3 02              .byte    $02            ; Graphics + W = graphic
0381   00D4 04              .byte    $04            ; Graphics + E = graphic
0382   00D5 87              .byte    $87            ; Graphics + R = graphic
0383   00D6 81              .byte    $81            ; Graphics + T = graphic
0384   00D7             
0385   00D7 8F              .byte    $8F            ; Graphics + 1 = graphic
0386   00D8 8C              .byte    $8C            ; Graphics + 2 = graphic
0387   00D9 8E              .byte    $8E            ; Graphics + 3 = graphic
0388   00DA 8D              .byte    $8D            ; Graphics + 4 = inverse $
0389   00DB 8B              .byte    $8B            ; Graphics + 5 = inverse "
0390   00DC             
0391   00DC 94              .byte    $94            ; Graphics + 0 = inverse =
0392   00DD 91              .byte    $91            ; Graphics + 9 = inverse )
0393   00DE 90              .byte    $90            ; Graphics + 8 = inverse (
0394   00DF 9A              .byte    $9A            ; Graphics + 7 = inverse ,
0395   00E0 99              .byte    $99            ; Graphics + 6 = inverse ;
0396   00E1             
0397   00E1 92              .byte    $92            ; Graphics + P = inverse >
0398   00E2 93              .byte    $93            ; Graphics + O = inverse <
0399   00E3 07              .byte    $07            ; Graphics + I = graphic
0400   00E4 84              .byte    $84            ; Graphics + U = graphic
0401   00E5 82              .byte    $82            ; Graphics + Y = graphic
0402   00E6             
0403   00E6 78              .byte    $78            ; Graphics + N/L = KL
0404   00E7 95              .byte    $95            ; Graphics + L = inverse +
0405   00E8 96              .byte    $96            ; Graphics + K = inverse -
0406   00E9 97              .byte    $97            ; Graphics + J = inverse *
0407   00EA 98              .byte    $98            ; Graphics + H = inverse /
0408   00EB             
0409   00EB 78              .byte    $78            ; Graphics + SPACE =
0410   00EC 77              .byte    $77            ; Graphics + . = RUBOUT
0411   00ED 78              .byte    $78            ; Graphics + M = KL
0412   00EE 86              .byte    $86            ; Graphics + N = graphic
0413   00EF 06              .byte    $06            ; Graphics + B = graphic
