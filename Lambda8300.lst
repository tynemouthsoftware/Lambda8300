0788   033D             ; ----------------------------------
0789   033D             
0790   033D             ; KEYBOARD
0791   033D             sub_033dh:
0792   033D 21 FF FF        ld hl,0ffffh
0793   0340 01 FE FE        ld bc,0fefeh
0794   0343 ED 78           in a,(c)                ; Read port $FE, starts VSync pulse
0795   0345 F6 01           or 001h                 ; Ignore shift
0796   0347             
0797   0347             ; EACH-LINE
0798   0347             l0347h:
0799   0347 F6 E0           or 0e0h
