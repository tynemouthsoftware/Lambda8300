0461   0173 33 2A BC        .byte   $33,$2A,$3C+$80                 ; NEW
0462   0176 38 28 37 34     .byte   $38,$28,$37,$34,$31,$31+$80     ; SCROLL
0462   017A 31 B1 
0463   017C 28 34 33 B9     .byte   $28,$34,$33,$39+$80             ; CONT
0464   0180 29 2E B2        .byte   $29,$2E,$32+$80                 ; DIM
0465   0183 37 2A B2        .byte   $37,$2A,$32+$80                 ; REM
0466   0186 2B 34 B7        .byte   $2B,$34,$37+$80                 ; FOR
0467   0189 2C 34 39 B4     .byte   $2C,$34,$39,$34+$80             ; GOTO
0468   018D 2C 34 38 3A     .byte   $2C,$34,$38,$3A,$27+$80         ; GOSUB
0468   0191 A7 
0469   0192 2E 33 35 3A     .byte   $2E,$33,$35,$3A,$39+$80         ; INPUT
0469   0196 B9 
0470   0197 31 34 26 A9     .byte   $31,$34,$26,$29+$80             ; LOAD
0471   019B 31 2E 38 B9     .byte   $31,$2E,$38,$39+$80             ; LIST
0472   019F 31 2A B9        .byte   $31,$2A,$39+$80                 ; LET
0473   01A2 35 26 3A 38     .byte   $35,$26,$3A,$38,$2A+$80         ; PAUSE
0473   01A6 AA 
0474   01A7 33 2A 3D B9     .byte   $33,$2A,$3D,$39+$80             ; NEXT
0475   01AB 35 34 30 AA     .byte   $35,$34,$30,$2A+$80             ; POKE
0476   01AF 35 37 2E 33     .byte   $35,$37,$2E,$33,$39+$80         ; PRINT
0476   01B3 B9 
0477   01B4 35 31 34 B9     .byte   $35,$31,$34,$39+$80             ; PLOT
0478   01B8 37 3A B3        .byte   $37,$3A,$33+$80                 ; RUN
0479   01BB 38 26 3B AA     .byte   $38,$26,$3B,$2A+$80             ; SAVE
0480   01BF 37 26 33 A9     .byte   $37,$26,$33,$29+$80             ; RAND
0481   01C3 2E AB           .byte   $2E,$2B+$80                     ; IF
0482   01C5 28 31 B8        .byte   $28,$31,$38+$80                 ; CLS
0483   01C8 3A 33 35 31     .byte   $3A,$33,$35,$31,$34,$39+$80     ; UNPLOT
0483   01CC 34 B9 
0484   01CE 28 31 2A 26     .byte   $28,$31,$2A,$26,$37+$80         ; CLEAR
0484   01D2 B7 
0485   01D3 37 2A 39 3A     .byte   $37,$2A,$39,$3A,$37,$33+$80     ; RETURN
0485   01D7 37 B3 
0486   01D9 28 34 35 BE     .byte   $28,$34,$35,$3E+$80             ; COPY
0487   01DD             
0488   01DD 39 2D 2A B3     .byte   $39,$2D,$2A,$33+$80             ; THEN
0489   01E1 39 B4           .byte   $39,$34+$80                     ; TO
0490   01E3 38 39 2A B5     .byte   $38,$39,$2A,$35+$80             ; STEP
0491   01E7 37 33 A9        .byte   $37,$33,$29+$80                 ; RND
0492   01EA 2E 33 30 2A     .byte   $2E,$33,$30,$2A,$3E,$0D+$80     ; INKEY$
0492   01EE 3E 8D 
0493   01F0 35 AE           .byte   $35,$2E+$80                     ; PI
