0511   0204 38 39           .byte    $38,$39        ; 08 = ST - STop
0512   0206 26 2C           .byte    $26,$2C        ; 09 = AG - invalid ArGument
0513   0208 2E 37           .byte    $2E,$37        ; 0A = IR - Integer out of Range
0514   020A 2E 2A           .byte    $2E,$2A        ; 0B = IE - Invalid Expression
