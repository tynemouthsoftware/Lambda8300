0931   03CB 18 E0           jr l03adh
0932   03CD             
0933   03CD             ; --------------------------
0934   03CD             ; THE 'LOAD COMMAND' ROUTINE
0935   03CD             ; --------------------------
0936   03CD             
0937   03CD             ; LOAD
0938   03CD             sub_03cdh:
0939   03CD CD 35 04        call sub_0435h
0940   03D0 CB 12           rl d
0941   03D2 CB 0A           rrc d
0942   03D4             ; NEXT-PROG
0943   03D4             l03d4h:
