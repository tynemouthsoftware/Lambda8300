0720   02FD CD 14 03        call sub_0314h
0721   0300             
0722   0300             ; ---------------------
0723   0300             ; THE 'VIDEO-1' ROUTINE
0724   0300             ; ---------------------
0725   0300             
0726   0300             ; R-IX-1 (timing altered)
0727   0300 01 01 19        ld bc,01901h            ; B=25 lines, C=1 scanline
0728   0303 3A 00 00        ld a,(l0000h)           ; wasting cycles
0729   0306 3E F5           ld a,0f5h               ; Preset value to go into R to cause trigger at correct time
0730   0308 CD 37 03        call sub_0337h          ; DISPLAY-5, border complete, generate text display
0731   030B 00              nop
0732   030C 00              nop
0733   030D 2B              dec hl                  ; back to the previous HALT character
0734   030E CD 14 03        call sub_0314h          ; DISPLAY-3, bottom border
0735   0311 C3 9D 02        jp l029dh               ; Back to DISPLAY-1
0736   0314             
0737   0314             ; ---------------------------------
0738   0314             ; THE 'DISPLAY BLANK LINES' ROUTINE
0739   0314             ; ---------------------------------
0740   0314             
0741   0314             ; DISPLAY-3
0742   0314             sub_0314h:
0743   0314 DD E1           pop ix
0744   0316 FD 4E 28        ld c,(iy+028h)          ; Load C with MARGIN value
0745   0319 FD CB 3B 7E     bit 7,(iy+03bh)         ; Check CDFLAG
0746   031D 28 0C           jr z,l032bh             ; To DISPLAY-4 in FAST mode
0747   031F             
0748   031F 79              ld a,c                  ; A = 31 (NTSC) or 55 (PAL)
0749   0320 ED 44           neg
0750   0322 3C              inc a
0751   0323 08              ex af,af'               ; Set NMI's A register to $FF-MARGIN
0752   0324             
0753   0324 D3 FE           out (0feh),a            ; Enable the NMI generator
0754   0326             
0755   0326 E1              pop hl                  ; Restore main registers
0756   0327 D1              pop de
0757   0328 C1              pop bc
0758   0329 F1              pop af
0759   032A C9              ret                     ; return to users code until interrupted
0760   032B             
0761   032B             ; ------------------------
0762   032B             ; THE 'FAST MODE' ROUTINES
0763   032B             ; ------------------------
0764   032B             
0765   032B             ; DISPLAY-4
0766   032B             l032bh:
0767   032B 3E FC           ld a,0fch               ; Set delay
0768   032D 06 01           ld b,001h               ; For 1 row
0769   032F CD 37 03        call sub_0337h          ; To DISPLAY-5
0770   0332 2B              dec hl                  ; Back to previous HALT
0771   0333 E3              ex (sp),hl              ; Waste cycles
0772   0334 E3              ex (sp),hl
0773   0335 DD E9           jp (ix)                 ; Back to R-IX-1 or R-IX-2
0774   0337             
0775   0337             ; --------------------------
0776   0337             ; THE 'DISPLAY-5' SUBROUTINE
0777   0337             ; --------------------------
0778   0337             
0779   0337             ; DISPLAY-5
0780   0337             sub_0337h:
0781   0337 ED 4F           ld r,a                  ; R= $FC (SLOW mode) or $FC (FAST mode)
0782   0339 3E DD           ld a,0ddh               ; Preload next R
0783   033B FB              ei                      ; Enable interrupts at the end of lines
0784   033C E9              jp (hl)                 ; Jump into the echo display file
0785   033D             
