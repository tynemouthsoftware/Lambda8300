0495   01F2             ; ---------------------------
0496   01F2             ; THE 'ERROR MESSAGES' TABLES
0497   01F2             ; ---------------------------
0498   01F2             
0499   01F2             ; table of error messages, used by function at $07E1
0500   01F2             l01f2h:
0501   01F2 34 30           .byte    $34,$30        ; FF = OK - OK
0502   01F4 33 2B           .byte    $33,$2B        ; 00 = NF - NEXT without FOR
0503   01F6 3A 3B           .byte    $3A,$3B        ; 01 = UV - Unidentified Variable
0504   01F8 27 38           .byte    $27,$38        ; 02 = BS - Bad Subscript
0505   01FA 34 32           .byte    $34,$32        ; 03 = OM - Out of Memory
0506   01FC 38 2B           .byte    $38,$2B        ; 04 = SF - Screen Full
0507   01FE 34 3B           .byte    $34,$3B        ; 05 = OV - OVerflow
0508   0200 37 2C           .byte    $37,$2C        ; 06 = RG - RETURN without GOSUB
0509   0202 2E 2E           .byte    $2E,$2E        ; 07 = II - Illegal INPUT
0510   0204 38 39           .byte    $38,$39        ; 08 = ST - STop
0511   0206 26 2C           .byte    $26,$2C        ; 09 = AG - invalid ArGument
0512   0208 2E 37           .byte    $2E,$37        ; 0A = IR - Integer out of Range
0513   020A 2E 2A           .byte    $2E,$2A        ; 0B = IE - Invalid Expression
0514   020C 27 30           .byte    $27,$30        ; 0C = BK - BreaK
0515   020E 33 26           .byte    $33,$26        ; 0D = NA - No program NAme
0516   0210 32 2B           .byte    $32,$2B        ; 0E = MF - Music Format incorrect
0517   0212             
0518   0212             ; the " IN " message
0519   0212             l0212h:
0520   0212 00 2E 33 00     .byte    $00,$2E,$33,$00    ; " IN " ("OK IN 10")
0521   0216             
0522   0216             
0523   0216             ; ------------------------------
0524   0216             ; THE 'LOAD-SAVE UPDATE' ROUTINE
0525   0216             ; ------------------------------
0526   0216             
0527   0216             ; LOAD/SAVE
0528   0216             sub_0216h:
0529   0216 23              inc hl                  ; Step destination
0530   0217 EB              ex de,hl                ; Backup to DE
0531   0218 2A 14 40        ld hl,(04014h)          ; Get E-LINE
0532   021B 37              scf                     ; Check if they match
0533   021C ED 52           sbc hl,de               ; Is the last byte the end of the file?
0534   021E EB              ex de,hl                ; Restore destination
0535   021F D0              ret nc                  ; return if the end has not been reached
0536   0220 E1              pop hl                  ; drop the return address and continue
0537   0221             ; ZX81 drops to SLOW here
0538   0221             
0539   0221             ; LOAD/SAVE-COMPLETE
0540   0221             l0221h:
0541   0221 FD 34 09        inc (iy+009h)           ; increment version (from tape Lambda = $FF, ZX81 = $00. normal Lambda = $00, ZX81 = $01)
0542   0224 28 5F           jr z,sub_0285h          ; if it was $FF, a Lambda program, go straight to FAST/SLOW
0543   0226             
0544   0226             ; This code converts a ZX81 program to the Lambda 8300
0545   0226 2A 0C 40        ld hl,(0400ch)          ; Location of the ZX81 DFILE (loaded with program)
0546   0229 23              inc hl                  ; +1
0547   022A 22 10 40        ld (04010h),hl          ; Store this as
0548   022D 21 7D 40        ld hl,DFILE             ; Hard coded DFILE location
0549   0230 01 19 03        ld bc,00319h            ; Length of DFILE + 1 extra blank row to make SCROLL a block copy
0550   0233 CD 30 0B        call sub_0b30h          ; MAKE-ROOM for BC bytes at location in HL
0551   0236 EB              ex de,hl                ; HL is now at the program location
0552   0237             ; ZX81-CONV-1
0553   0237             l0237h:
0554   0237 23              inc hl                  ; Step through memory
0555   0238 3E C0           ld a,0c0h
0556   023A A6              and (hl)                ; Mask off the top two bits
0557   023B 23              inc hl
0558   023C 23              inc hl
0559   023D 23              inc hl
0560   023E 28 08           jr z,l0248h             ; If it was <$30, skip to ZX81-CONV-4
0561   0240 21 96 43        ld hl,04396h            ; Hard coded number we worked out before (start of program)
0562   0243 C3 AC 04        jp l04ach               ; Re-initialise after loading and clear screen etc.
0563   0246             
0564   0246             ; ZX81-CONV-2
0565   0246             l0246h:
0566   0246 80              add a,b                 ; modify the command token from ZX81 to Lambda tokens
0567   0247             
0568   0247             ; ZX81-CONV-3
0569   0247             l0247h:
0570   0247 77              ld (hl),a               ; update the token in the copde
0571   0248             
0572   0248             ; ZX81-CONV-4
0573   0248             l0248h:
0574   0248 23              inc hl                  ; step through program
0575   0249 7E              ld a,(hl)
0576   024A CD 55 09        call sub_0955h          ; routine NUMBER
0577   024D 28 F9           jr z,l0248h             ; skip through numbers
0578   024F             
0579   024F FE 76           cp 076h                 ; is it a newline?
0580   0251 28 E4           jr z,l0237h             ; skip back for next line number
0581   0253 FE E1           cp 0e1h                 ; is it a command over $E1?
0582   0255 30 F1           jr nc,l0248h            ; continue scanning
0583   0257 FE 40           cp 040h                 ; is it a number character below $40?
0584   0259 38 ED           jr c,l0248h             ; continue scanning
0585   025B 06 03           ld b,003h
0586   025D FE 43           cp 043h                 ; is it a command below $43?
0587   025F 38 E5           jr c,l0246h             ; add 3
0588   0261 06 62           ld b,062h
0589   0263 FE DE           cp 0deh                 ; is it a command above $DE?
0590   0265 30 DF           jr nc,l0246h            ; add $62
0591   0267 06 FE           ld b,0feh
0592   0269 FE D8           cp 0d8h                 ; is it cpmmand $D8?
0593   026B 30 D9           jr nc,l0246h            ; add $FE
0594   026D 06 FC           ld b,0fch
0595   026F FE C4           cp 0c4h                 ; is it above $C4?
0596   0271 30 D3           jr nc,l0246h            ; add $FC
0597   0273 06 13           ld b,013h
0598   0275 FE C1           cp 0c1h                 ; is it above $C1?
0599   0277 30 CD           jr nc,l0246h            ; add $13
0600   0279 FE C0           cp 0c0h
0601   027B 20 CB           jr nz,l0248h            ; is it not $C0?
0602   027D 3E 17           ld a,017h               ; replace with dummy command
0603   027F 18 C6           jr l0247h               ; loop back to write the new value
0604   0281             
0605   0281             ; --------------------------
0606   0281             ; THE 'SLOW' COMMAND ROUTINE
0607   0281             ; --------------------------
0608   0281             
0609   0281             ; SLOW
0610   0281             sub_0281h:
0611   0281 FD CB 3B F6     set 6,(iy+03bh)         ; Request slow mode ()
0612   0285             
0613   0285             ; SLOW/FAST
0614   0285             sub_0285h:
0615   0285 21 3B 40        ld hl,0403bh            ; load the CDFLAG
0616   0288 7E              ld a,(hl)
0617   0289 17              rla                     ; bit 6 (request) -> bit 7 (current state)
0618   028A AE              xor (hl)                ; XOR with actual current state
0619   028B 17              rla                     ; result -> carry
0620   028C D0              ret nc                  ; return if already in requested mode
0621   028D             
0622   028D CB FE           set 7,(hl)              ; set slow mode - compute and display
0623   028F F5              push af
0624   0290 C5              push bc
0625   0291 D5              push de
0626   0292 E5              push hl
0627   0293             
0628   0293             ; Called where DISPLAY-1 usually was
0629   0293             ; PRE-DISPLAY-1
0630   0293             sub_0293h:
0631   0293 AF              xor a                   ; clear the line counter
0632   0294 08              ex af,af'
0633   0295 D3 FE           out (0feh),a            ; enable NMI generator
0634   0297 76              halt                    ; wait for interrupt
0635   0298 D3 FD           out (0fdh),a            ; disable NMI generator
0636   029A 7E              ld a,(hl)               ; waste cycles
0637   029B 7E              ld a,(hl)
0638   029C 00              nop
0639   029D             
0640   029D             ; -----------------------
0641   029D             ; THE 'MAIN DISPLAY' LOOP
0642   029D             ; -----------------------
0643   029D             ; This routine is executed once for every frame displayed.
0644   029D             
0645   029D             ;; DISPLAY-1
0646   029D             l029dh:
0647   029D 2A 34 40        ld hl,(04034h)          ; Get the frame count from FRAMES
0648   02A0 2B              dec hl
0649   02A1 3E 7F           ld a,07fh               ; Mask bit 7
0650   02A3 A4              and h                   ; of H
0651   02A4 B5              or l                    ; and OR with L
0652   02A5 7C              ld a,h                  ;
0653   02A6 20 03           jr nz,l02abh            ; Jump if frame counter bits 0-14 are zero
0654   02A8 17              rla                     ; bit 15 of frame counter (1 if paused) to carry
0655   02A9 18 02           jr l02adh               ; skip
0656   02AB             
0657   02AB             ; ANOTHER
0658   02AB             l02abh:
0659   02AB 46              ld b,(hl)               ; Dummy timing
0660   02AC 37              scf                     ; set carry
0661   02AD             
0662   02AD             ; OVER-NC
0663   02AD             l02adh:
0664   02AD 67              ld h,a
0665   02AE 22 34 40        ld (04034h),hl          ; Save the new frame count to FRAMES
0666   02B1 D0              ret nc                  ; Return if FRAMES is in use by PAUSE command
0667   02B2             
0668   02B2             ; ZX81 goes string to ; DISPLAY-2
0669   02B2             
0670   02B2             ; Bit 7 of the cursor character is inverted every 16 frames
0671   02B2             ; That makes it flashe approximately 2 times a second
0672   02B2             ; BLINK-CURSOR
0673   02B2 7D              ld a,l                  ; A = LSB of FRAMES
0674   02B3 2A 7B 40        ld hl,(0407bh)          ; Address of blinking cursor
0675   02B6 CB 26           sla (hl)                ; rotate cursor character
0676   02B8 17              rla                     ;
0677   02B9 17              rla                     ;
0678   02BA 17              rla                     ;
0679   02BB 17              rla                     ; rotate A bit 4 into carry
0680   02BC CB 1E           rr (hl)                 ; rotate carry back into character
0681   02BE             
0682   02BE             ; DISPLAY-2
0683   02BE CD 3D 03        call sub_033dh          ; KEYBOARD - scan keyboard and start VSYNC
0684   02C1 ED 4B 25 40     ld bc,(04025h)          ; get LAST_K
0685   02C5 22 25 40        ld (04025h),hl          ; update LAST_K
0686   02C8 78              ld a,b
0687   02C9 C6 02           add a,002h
0688   02CB ED 42           sbc hl,bc
0689   02CD 3A 27 40        ld a,(04027h)           ; Check DEBOUNCE
0690   02D0 B4              or h
0691   02D1 B5              or l
0692   02D2 58              ld e,b
0693   02D3 06 09           ld b,009h               ; ZX81 used $0B
0694   02D5 21 3B 40        ld hl,0403bh            ; Get CDFLAG
0695   02D8 CB 86           res 0,(hl)
0696   02DA 20 08           jr nz,l02e4h
0697   02DC CB 7E           bit 7,(hl)
0698   02DE CB C6           set 0,(hl)
0699   02E0 C8              ret z                   ; return if in FAST mode
0700   02E1 05              dec b
0701   02E2 05              dec b                   ; extra DEC B, ZX81 was NOP
0702   02E3 37              scf
0703   02E4             
0704   02E4             ; NO-KEY
0705   02E4             l02e4h:
0706   02E4 CB 10           rl b                    ; Reordered from ZX81
0707   02E6             
0708   02E6             ; LOOP-B
0709   02E6             l02e6h:
0710   02E6 10 FE           djnz l02e6h
0711   02E8 21 27 40        ld hl,04027h
0712   02EB 46              ld b,(hl)               ; Get DEBOUCE
0713   02EC 7B              ld a,e
0714   02ED FE FE           cp 0feh
0715   02EF 9F              sbc a,a
0716   02F0 06 0F           ld b,00fh               ; ZX81 has $1F
0717   02F2 B6              or (hl)
0718   02F3 A0              and b
0719   02F4 1F              rra
0720   02F5 77              ld (hl),a
0721   02F6             l02f6h:
0722   02F6 29              add hl,hl
0723   02F7 23              inc hl
0724   02F8 D3 FF           out (0ffh),a            ; End VSYNC pulse
0725   02FA             
0726   02FA 21 7D C0        ld hl,$407D + $8000     ; Hard coded DFILE location
0727   02FD CD 14 03        call sub_0314h
0728   0300             
0729   0300             ; ---------------------
0730   0300             ; THE 'VIDEO-1' ROUTINE
0731   0300             ; ---------------------
0732   0300             
0733   0300             ; R-IX-1 (timing altered)
0734   0300 01 01 19        ld bc,01901h            ; B=25 lines, C=1 scanline
0735   0303 3A 00 00        ld a,(00000h)           ; wasting cycles
0736   0306 3E F5           ld a,0f5h               ; Preset value to go into R to cause trigger at correct time
0737   0308 CD 37 03        call sub_0337h          ; DISPLAY-5, border complete, generate text display
0738   030B 00              nop
0739   030C 00              nop
0740   030D 2B              dec hl                  ; back to the previous HALT character
0741   030E CD 14 03        call sub_0314h          ; DISPLAY-3, bottom border
0742   0311 C3 9D 02        jp l029dh               ; Back to DISPLAY-1
0743   0314             
0744   0314             ; ---------------------------------
0745   0314             ; THE 'DISPLAY BLANK LINES' ROUTINE
0746   0314             ; ---------------------------------
0747   0314             
0748   0314             ; DISPLAY-3
0749   0314             sub_0314h:
0750   0314 DD E1           pop ix
0751   0316 FD 4E 28        ld c,(iy+028h)          ; Load C with MARGIN value
0752   0319 FD CB 3B 7E     bit 7,(iy+03bh)         ; Check CDFLAG
0753   031D 28 0C           jr z,l032bh             ; To DISPLAY-4 in FAST mode
0754   031F             
0755   031F 79              ld a,c                  ; A = 31 (NTSC) or 55 (PAL)
0756   0320 ED 44           neg
0757   0322 3C              inc a
0758   0323 08              ex af,af'               ; Set NMI's A register to $FF-MARGIN
0759   0324             
0760   0324 D3 FE           out (0feh),a            ; Enable the NMI generator
0761   0326             
0762   0326 E1              pop hl                  ; Restore main registers
0763   0327 D1              pop de
0764   0328 C1              pop bc
0765   0329 F1              pop af
0766   032A C9              ret                     ; return to users code until interrupted
0767   032B             
0768   032B             ; ------------------------
0769   032B             ; THE 'FAST MODE' ROUTINES
0770   032B             ; ------------------------
0771   032B             
0772   032B             ; DISPLAY-4
0773   032B             l032bh:
0774   032B 3E FC           ld a,0fch               ; Set delay
0775   032D 06 01           ld b,001h               ; For 1 row
0776   032F CD 37 03        call sub_0337h          ; To DISPLAY-5
0777   0332 2B              dec hl                  ; Back to previous HALT
0778   0333 E3              ex (sp),hl              ; Waste cycles
0779   0334 E3              ex (sp),hl
0780   0335 DD E9           jp (ix)                 ; Back to R-IX-1 or R-IX-2
0781   0337             
0782   0337             ; --------------------------
0783   0337             ; THE 'DISPLAY-5' SUBROUTINE
0784   0337             ; --------------------------
0785   0337             
0786   0337             ; DISPLAY-5
0787   0337             sub_0337h:
0788   0337 ED 4F           ld r,a                  ; R= $FC (SLOW mode) or $FC (FAST mode)
0789   0339 3E DD           ld a,0ddh               ; Preload next R
0790   033B FB              ei                      ; Enable interrupts at the end of lines
0791   033C E9              jp (hl)                 ; Jump into the echo display file
0792   033D             
0793   033D             ; ----------------------------------
0794   033D             ; THE 'KEYBOARD SCANNING' SUBROUTINE
0795   033D             ; ----------------------------------
0796   033D             
0797   033D             ; KEYBOARD
0798   033D             sub_033dh:
0799   033D 21 FF FF        ld hl,0ffffh
0800   0340 01 FE FE        ld bc,0fefeh
0801   0343 ED 78           in a,(c)                ; Read port $FE, starts VSync pulse
0802   0345 F6 01           or 001h                 ; Ignore shift
0803   0347             
0804   0347             ; EACH-LINE
0805   0347             l0347h:
0806   0347 F6 E0           or 0e0h
0807   0349 57              ld d,a
0808   034A 2F              cpl
0809   034B FE 01           cp 001h
0810   034D 9F              sbc a,a
0811   034E B0              or b
0812   034F A5              and l
0813   0350 6F              ld l,a
0814   0351 7C              ld a,h
0815   0352 A2              and d
0816   0353 67              ld h,a
0817   0354 CB 00           rlc b
0818   0356 ED 78           in a,(c)
0819   0358 38 ED           jr c,l0347h
0820   035A 1F              rra
0821   035B CB 14           rl h
0822   035D             
0823   035D             ; GET_REGION
0824   035D 3E FF           ld a,0ffh               ; Read port $7E
0825   035F DB 7E           in a,(07eh)             ; Will return the same as $FE unless there is something different in the Lambda
0826   0361 1F              rra                     ; Bit 7 => carry (Bit 7 that is the tape input???)
0827   0362 3F              ccf                     ; carry = !carry
0828   0363 9F              sbc a,a                 ; A = $FF (PAL) or $00 (NTSC)
0829   0364 E6 18           and 018h                ; A = $18       or $00
0830   0366 C6 1F           add a,01fh              ; A = $37       or $1F
0831   0368 32 28 40        ld (04028h),a           ; Save this as MARGIN
0832   036B C9              ret
0833   036C             
0834   036C             ; --------------------------
0835   036C             ; THE 'FAST' COMMAND ROUTINE
0836   036C             ; --------------------------
0837   036C             ; FAST
0838   036C             sub_036ch:
0839   036C FD CB 3B B6     res 6,(iy+03bh)         ; Request FAST mode
0840   0370             
0841   0370             ; ------------------------------
0842   0370             ; THE 'SET FAST MODE' SUBROUTINE
0843   0370             ; ------------------------------
0844   0370             
0845   0370             ; SET-FAST
0846   0370             sub_0370h:
0847   0370 FD CB 3B 7E     bit 7,(iy+03bh)         ; Test FAST mode
0848   0374 C8              ret z                   ; Already in Fast mode
0849   0375 76              halt                    ; Synchronise with interrupt
0850   0376             
0851   0376 D3 FD           out (0fdh),a            ; Disable NMI generator (value of A unimportant)
0852   0378 FD CB 3B BE     res 7,(iy+03bh)         ; Set FAST mode
0853   037C C9              ret
0854   037D             
0855   037D             ; --------------
0856   037D             ; THE 'REPORT-F'
0857   037D             ; --------------
0858   037D             
0859   037D             ;; REPORT-F
0860   037D             l037dh:
0861   037D CF              rst 08h                 ; ERROR-1
0862   037E 0D              .byte $0D               ; NA - po program NAme supplied.
0863   037F             
0864   037F             ; --------------------------
0865   037F             ; THE 'SAVE COMMAND' ROUTINE
0866   037F             ; --------------------------
0867   037F             
0868   037F             ; SAVE
0869   037F             sub_037fh:
0870   037F CD 35 04        call sub_0435h
0871   0382 38 F9           jr c,l037dh
0872   0384 FD 36 09 FF     ld (iy+009h),0ffh       ; Set version to $FF, indicating Lambda 8300 program
0873   0388 EB              ex de,hl
0874   0389 11 CB 12        ld de,012cbh            ; five seconds timing value
0875   038C             
0876   038C             ; HEADER
0877   038C             l038ch:
0878   038C CD 3B 11        call sub_113bh
0879   038F 30 2E           jr nc,l03bfh
0880   0391             
0881   0391             ; DELAY-1
0882   0391             l0391h:
0883   0391 10 FE           djnz l0391h
0884   0393 1B              dec de
0885   0394 7A              ld a,d
0886   0395 B3              or e
0887   0396 20 F4           jr nz,l038ch
0888   0398             
0889   0398             ; OUT-NAME
0890   0398             l0398h:
0891   0398 CD AB 03        call sub_03abh
0892   039B CB 7E           bit 7,(hl)
0893   039D 23              inc hl
0894   039E 28 F8           jr z,l0398h
0895   03A0 21 09 40        ld hl,04009h            ; Set HL to first address to go, VERSN
0896   03A3             
0897   03A3             ; OUT-PROG
0898   03A3             l03a3h:
0899   03A3 CD AB 03        call sub_03abh
0900   03A6 CD 16 02        call sub_0216h
0901   03A9 18 F8           jr l03a3h
0902   03AB             
0903   03AB             ; -------------------------
0904   03AB             ; THE 'OUT-BYTE' SUBROUTINE
0905   03AB             ; -------------------------
0906   03AB             
0907   03AB             ; OUT-BYTE
0908   03AB             sub_03abh:
0909   03AB 5E              ld e,(hl)
0910   03AC 37              scf
0911   03AD             
0912   03AD             ; EACH-BIT
0913   03AD             l03adh:
0914   03AD CB 13           rl e
0915   03AF C8              ret z
0916   03B0 9F              sbc a,a
0917   03B1 E6 05           and 005h
0918   03B3 C6 04           add a,004h
0919   03B5 4F              ld c,a
0920   03B6             
0921   03B6             ; PULSES
0922   03B6             l03b6h:
0923   03B6 D3 FF           out (0ffh),a
0924   03B8 06 23           ld b,023h
0925   03BA             
0926   03BA             ; DELAY-2
0927   03BA             l03bah:
0928   03BA 10 FE           djnz l03bah
0929   03BC CD 3B 11        call sub_113bh
0930   03BF             
0931   03BF             ; BREAK-2
0932   03BF             l03bfh:
0933   03BF 30 72           jr nc,l0433h
0934   03C1 06 1E           ld b,01eh
0935   03C3             
0936   03C3             ; DELAY-3
0937   03C3             l03c3h:
0938   03C3 10 FE           djnz l03c3h
0939   03C5 0D              dec c
0940   03C6 20 EE           jr nz,l03b6h
0941   03C8             
0942   03C8             ; DELAY-4
0943   03C8             l03c8h:
0944   03C8 A7              and a
0945   03C9 10 FD           djnz l03c8h
0946   03CB 18 E0           jr l03adh
0947   03CD             
0948   03CD             ; --------------------------
0949   03CD             ; THE 'LOAD COMMAND' ROUTINE
0950   03CD             ; --------------------------
0951   03CD             
0952   03CD             ; LOAD
0953   03CD             sub_03cdh:
0954   03CD CD 35 04        call sub_0435h          ; Routine NAME
0955   03D0                                         ; DE points to start of name in RAM
0956   03D0 CB 12           rl d                    ; Pick up carry
0957   03D2 CB 0A           rrc d                   ; Carry now in bit 7
0958   03D4             
0959   03D4             ; NEXT-PROG
0960   03D4             l03d4h:
0961   03D4 CD D9 03        call sub_03d9h          ; routine IN-BYTE
0962   03D7 18 FB           jr l03d4h               ; loop to NEXT-PROG
0963   03D9             
0964   03D9             ; ------------------------
0965   03D9             ; THE 'IN-BYTE' SUBROUTINE
0966   03D9             ; ------------------------
0967   03D9             
0968   03D9             ; IN-BYTE
0969   03D9             sub_03d9h:
0970   03D9 0E 01           ld c,001h               ; Byte counter
0971   03DB             
0972   03DB             ; NEXT-BIT
0973   03DB             l03dbh:
0974   03DB 06 00           ld b,000h               ; Loop 256 times
0975   03DD             
0976   03DD             ; BREAK-3
0977   03DD             l03ddh:
0978   03DD 3E 7F           ld a,07fh               ; Check the space key
0979   03DF DB FE           in a,(0feh)             ;
0980   03E1 D3 FF           out (0ffh),a            ; IO Write triggers VYsnc pulses on screen
0981   03E3 1F              rra                     ; check for space pressed (bit 0->Carry)
0982   03E4 30 49           jr nc,l042fh            ; to BREAK-4 if so
0983   03E6 17              rla                     ; Carry->bit 0
0984   03E7 17              rla                     ; bit 7->Carry
0985   03E8 38 28           jr c,l0412h             ; Forward to GET-BIT if there is data
0986   03EA 10 F1           djnz l03ddh             ; Loop back and keep checking
0987   03EC F1              pop af                  ; Drop return address
0988   03ED BA              cp d                    ; But A holds the value from port FE?
0989   03EE             
0990   03EE             ; RESTART
0991   03EE             l03eeh:
0992   03EE D2 A3 04        jp nc,l04a3h
0993   03F1 62              ld h,d
0994   03F2 6B              ld l,e
0995   03F3             
0996   03F3             ; IN-NAME
0997   03F3             l03f3h:
0998   03F3 CD D9 03        call sub_03d9h
0999   03F6 CB 7A           bit 7,d
1000   03F8 79              ld a,c
1001   03F9 20 03           jr nz,l03feh
1002   03FB BE              cp (hl)
1003   03FC 20 D6           jr nz,l03d4h
1004   03FE             
1005   03FE             ; MATCHING
1006   03FE             l03feh:
1007   03FE 23              inc hl
1008   03FF 17              rla
1009   0400 30 F1           jr nc,l03f3h
1010   0402 FD 34 15        inc (iy+015h)
1011   0405 21 09 40        ld hl,04009h
1012   0408             
1013   0408             ; IN-PROG
1014   0408             l0408h:
1015   0408 50              ld d,b
1016   0409 CD D9 03        call sub_03d9h
1017   040C 71              ld (hl),c
1018   040D CD 16 02        call sub_0216h
1019   0410 18 F6           jr l0408h
1020   0412             
1021   0412             ; GET-BIT
1022   0412             l0412h:
1023   0412 D5              push de
1024   0413 1E 94           ld e,094h
1025   0415             
1026   0415             ; TRAILER
1027   0415             l0415h:
1028   0415 06 1A           ld b,01ah
1029   0417             
1030   0417             ; COUNTER
1031   0417             l0417h:
1032   0417 1D              dec e
1033   0418 DB FE           in a,(0feh)
1034   041A 17              rla
1035   041B CB 7B           bit 7,e
1036   041D 7B              ld a,e
1037   041E 38 F5           jr c,l0415h
1038   0420 10 F5           djnz l0417h
1039   0422 D1              pop de
1040   0423 20 04           jr nz,l0429h
1041   0425 FE 56           cp 056h
1042   0427 30 B2           jr nc,l03dbh
1043   0429             
1044   0429             ; BIT-DONE
1045   0429             l0429h:
1046   0429 3F              ccf
1047   042A CB 11           rl c
1048   042C 30 AD           jr nc,l03dbh
1049   042E C9              ret
1050   042F             
1051   042F             ; BREAK-4
1052   042F             l042fh:
1053   042F 7A              ld a,d                  ; Get D
1054   0430 A7              and a                   ; Test it
1055   0431 28 BB           jr z,l03eeh             ; If there has been data, then restart
1056   0433             
1057   0433             ; REPORT-D
1058   0433             l0433h:
1059   0433 CF              rst 08h                 ; ERROR-1
1060   0434 0C              .byte $0C               ; Error Report: BREAK - CONT repeats
1061   0435             
1062   0435             ; -----------------------------
1063   0435             ; THE 'PROGRAM NAME' SUBROUTINE
1064   0435             ; -----------------------------
1065   0435             
1066   0435             ; NAME
1067   0435             sub_0435h:
1068   0435 CD 4A 11        call sub_114ah          ; routine SCANNING
1069   0438 3A 01 40        ld a,(04001h)
1070   043B 87              add a,a
1071   043C FA 17 0F        jp m,l0f17h             ; to REPORT-C - Invalid Expression
1072   043F E1              pop hl
1073   0440 D0              ret nc
1074   0441 E5              push hl
1075   0442 CD 70 03        call sub_0370h          ; routine SET-FAST
1076   0445 CD ED 15        call sub_15edh          ; routine STK-FETCH
1077   0448 62              ld h,d
1078   0449 6B              ld l,e
1079   044A 0D              dec c
1080   044B F8              ret m
1081   044C 09              add hl,bc
1082   044D CB FE           set 7,(hl)
1083   044F C9              ret
1084   0450             
1085   0450             ; --------------------------
1086   0450             ; THE 'MAKE A NOISE' ROUTINE
1087   0450             ; --------------------------
1088   0450             
1089   0450             ; MAKE-NOISE
1090   0450             sub_0450h:
1091   0450 1E 20           ld e,020h               ; note = 32500/32 = 1.02KHz
1092   0452 01 00 18        ld bc,01800h            ; duration = 6144/65 = 94ms
1093   0455 18 09           jr l0460h               ; Routine PLAY-NOTE
1094   0457             
1095   0457             ; ----------------------------
1096   0457             ; THE 'SOUND' COMMAND ROUTINE
1097   0457             ; ----------------------------
1098   0457             
1099   0457             ; SOUND
1100   0457             sub_0457h:
1101   0457 CD 88 10        call sub_1088h          ; routine FIND-INT => BC
1102   045A C5              push bc
1103   045B CD 83 10        call sub_1083h          ; routine FIND-SHORT => A
1104   045E C1              pop bc
1105   045F 5F              ld e,a                  ; INT => E
1106   0460             
1107   0460             ; PLAY-NOTE
1108   0460             ; E = note, defined as 32500Hz/E, so (0=256=>127Hz) to (1=>32.5KHz)
1109   0460             ; BC = duration, defined as BC/65ms, so (1=>15ms) to (0=65536=>1 second)
1110   0460             ; Appox 4 times slower in SLOW mode
1111   0460             l0460h:
1112   0460 DB F5           in a,(0f5h)             ; Toggle beeper on read of $F5
1113   0462 53              ld d,e                  ; Note
1114   0463             ; PLAY-NOTE-2
1115   0463             l0463h:
1116   0463 0B              dec bc                  ; Duration
1117   0464 78              ld a,b
1118   0465 B1              or c
1119   0466 C8              ret z                   ; Return when BC=0
1120   0467 15              dec d
1121   0468 28 F6           jr z,l0460h             ; Toggle speaker when note countdown complete
1122   046A 00              nop
1123   046B 00              nop
1124   046C 18 F5           jr l0463h               ; Loop until complete
1125   046E             
1126   046E             
1127   046E             ; ---------------
1128   046E             ; START CONTINUED
1129   046E             ; ---------------
1130   046E             
1131   046E             ; START-3
1132   046E             l046eh:
1133   046E 1F              rra                     ; A was read from FE, column 0 -> C
1134   046F 2F              cpl
1135   0470 32 06 40        ld (04006h),a           ; set mode
1136   0473 01 FF BF        ld bc,0bfffh            ; top of possible RAM, making max RAM 32K
1137   0476 30 11           jr nc,l0489h            ; skip RAM test if key in column 0 held? autostart expansion ROM?
1138   0478 3A 7D 40        ld a,(DFILE)            ; check of there is a DFILE
1139   047B FE 76           cp 076h                 ; should start with a NL/HALT
1140   047D 20 0A           jr nz,l0489h            ; no DFILE, so do a cold start
1141   047F 28 3F           jr z,l04c0h             ; DFILE present, warm start, skip RAM test
1142   0481             
1143   0481             ; -------------------------
1144   0481             ; THE 'NEW' COMMAND ROUTINE
1145   0481             ; -------------------------
1146   0481             
1147   0481             ; NEW
1148   0481             sub_0481h:
1149   0481 CD 70 03        call sub_0370h          ; Set FAST mode
1150   0484 ED 4B 04 40     ld bc,(04004h)          ; RAMTOP top of detected / protected RAM
1151   0488 0B              dec bc
1152   0489             
1153   0489             ; -----------------------
1154   0489             ; THE 'RAM CHECK' ROUTINE
1155   0489             ; -----------------------
1156   0489             
1157   0489             ; RAM-CHECK
1158   0489             l0489h:
1159   0489 60              ld h,b                  ; HL = BC = last byte to test
1160   048A 69              ld l,c
1161   048B 3E 3F           ld a,03fh               ; stop point, check RAM down to $4000
1162   048D             
1163   048D             ; RAM-FILL
1164   048D             l048dh:
1165   048D 36 02           ld (hl),002h            ; write 2 to every address in RAM.
1166   048F 2B              dec hl
1167   0490 BC              cp h                    ; stop when H=A=$3F
1168   0491 20 FA           jr nz,l048dh
1169   0493             
1170   0493             ; RAM-READ
1171   0493             l0493h:
1172   0493 A7              and a                   ; reset carry flag
1173   0494 ED 42           sbc hl,bc               ; Compare HL and BC
1174   0496 09              add hl,bc               ;
1175   0497 23              inc hl                  ; HL = 4000 - what was the point in all that?
1176   0498 30 06           jr nc,l04a0h            ; if HL=BC, we're finished?
1177   049A 35              dec (hl)                ; Decrement RAM
1178   049B 28 03           jr z,l04a0h             ; Test if RAM was 1, but it would be picked up by the next test anyway?
1179   049D                                         ; I wonder if this was original a test for mirrors? but it doesn't do that now
1180   049D 35              dec (hl)                ; Decrement RAM
1181   049E 28 F3           jr z,l0493h             ; It was 2 previously, zero now, good RAM, keep checking
1182   04A0             
1183   04A0             ; SET-TOP
1184   04A0             l04a0h:
1185   04A0 22 04 40        ld (04004h),hl          ; Set RAMTOP, top of usable RAM
1186   04A3             
1187   04A3             ; ----------------------------------
1188   04A3             ; THE 'DFILE INITIALIZATION' ROUTINE
1189   04A3             ; ----------------------------------
1190   04A3             
1191   04A3             ; INIT-DFILE
1192   04A3             l04a3h:
1193   04A3 21 97 43        ld hl,04397h            ; Set VARS, starts of variable area
1194   04A6 22 10 40        ld (04010h),hl          ; VARS = $4397 - fixed location after DFILE
1195   04A9 2B              dec hl                  ; HL = 4396, start of program
1196   04AA 36 FF           ld (hl),0ffh
1197   04AC             l04ach:
1198   04AC 22 0C 40        ld (0400ch),hl          ; Set PRGRM
1199   04AF             
1200   04AF             ; CREATE-DFILE
1201   04AF 0E 19           ld c,019h               ; 24 lines + 1 extra NL
1202   04B1 AF              xor a                   ; A = 0 = Space
1203   04B2             
1204   04B2             ; NEXT-LINE
1205   04B2             l04b2h:
1206   04B2 2B              dec hl
1207   04B3 36 76           ld (hl),076h            ; start / end with newline / halt
1208   04B5 0D              dec c                   ; line counter
1209   04B6 28 08           jr z,l04c0h             ; finished?
1210   04B8             
1211   04B8             ; FILL-LINE
1212   04B8 06 20           ld b,020h               ; fill line with 32 spaces
1213   04BA             l04bah:
1214   04BA 2B              dec hl                  ; step backwards
1215   04BB 77              ld (hl),a               ; write a space
1216   04BC 10 FC           djnz l04bah             ; loop until done
1217   04BE 18 F2           jr l04b2h               ; back for more
1218   04C0             
1219   04C0             ; ----------------------------
1220   04C0             ; THE 'INITIALIZATION' ROUTINE
1221   04C0             ; ----------------------------
1222   04C0             
1223   04C0             ; INITIAL
1224   04C0             l04c0h:
1225   04C0 2A 04 40        ld hl,(04004h)          ; Get RAMTOP
1226   04C3 2B              dec hl                  ; Move to last system byte
1227   04C4 36 3E           ld (hl),03eh            ; Set GOSUB end marker
1228   04C6 2B              dec hl                  ; Move down again
1229   04C7 F9              ld sp,hl                ; Set stack here
1230   04C8 2B              dec hl                  ; Move to first location in stack
1231   04C9 2B              dec hl                  ;
1232   04CA 22 02 40        ld (04002h),hl          ; Set error stack pointer ERR_SP
1233   04CD                 ; I register is setup here on ZX81, not used on the Lambda,
1234   04CD                 ; The character ROM is inside the ULA
1235   04CD ED 56           im 1                    ; Z80 interrupt mode 1
1236   04CF FD 21 00 40     ld iy,04000h            ; Set IY to start of SYS VARS to make access easier
1237   04D3 FD 36 3B 40     ld (iy+03bh),040h       ; CDFLAG - compute and display mode requested
1238   04D7 FD 36 21 19     ld (iy+021h),019h       ; Set TEMPO to 25 (25*3.94ms = ~ 100ms)
1239   04DB AF              xor a                   ; Clear more flags
1240   04DC 32 19 40        ld (04019h),a           ; X_PTR_lo = 0
1241   04DF 32 2D 40        ld (0402dh),a           ; FLAGX = 0
1242   04E2 32 01 40        ld (04001h),a           ; FLAGS = 0
1243   04E5 32 7C 40        ld (0407ch),a           ; SPARE3 = 0
1244   04E8 3D              dec a                   ; A now $FF
1245   04E9 32 35 40        ld (04035h),a           ; FRAMES_lo = $FF
1246   04EC CD 92 16        call sub_1692h          ; CLEAR
1247   04EF CD 50 04        call sub_0450h          ; MAKE-NOISE
1248   04F2 CD 85 02        call sub_0285h          ; SLOW-FAST to set SLOW mode
1249   04F5 3A 06 40        ld a,(04006h)           ; check mode
1250   04F8 1F              rra
1251   04F9 DA 00 20        jp c,02000h             ; autostart expansion ROM?
1252   04FC             
1253   04FC             l04fch:
1254   04FC CD A5 16        call sub_16a5h          ; CURSOR-IN, set cursor on edit line
1255   04FF             
1256   04FF             ; ---------------------------
1257   04FF             ; THE 'BASIC LISTING' SECTION
1258   04FF             ; ---------------------------
1259   04FF             
1260   04FF             ; UPPER
1261   04FF             l04ffh:
1262   04FF CD D0 0B        call sub_0bd0h          ; CLS
1263   0502 2A 29 40        ld hl,(04029h)          ; E.PPC line number with cursor on (was $400A on ZX81)
1264   0505 ED 5B 23 40     ld de,(04023h)
1265   0509 A7              and a
1266   050A ED 52           sbc hl,de
1267   050C EB              ex de,hl
1268   050D 30 04           jr nc,l0513h
1269   050F 19              add hl,de
1270   0510 22 23 40        ld (04023h),hl
1271   0513             
1272   0513             ; ADDR-TOP
1273   0513             l0513h:
1274   0513 CD 6A 0B        call sub_0b6ah
1275   0516 28 01           jr z,l0519h
1276   0518 EB              ex de,hl
1277   0519             
1278   0519             ; LIST-TOP
1279   0519             l0519h:
1280   0519 CD CD 08        call sub_08cdh
1281   051C FD 35 1E        dec (iy+01eh)
1282   051F 20 37           jr nz,l0558h            ; routine LOWER
1283   0521 2A 29 40        ld hl,(04029h)          ; E.PPC line number with cursor on (was $400A on ZX81)
1284   0524 CD 6A 0B        call sub_0b6ah
1285   0527 2A 16 40        ld hl,(04016h)
1286   052A 37              scf
1287   052B ED 52           sbc hl,de
1288   052D 21 23 40        ld hl,04023h
1289   0530 30 0B           jr nc,l053dh
1290   0532 EB              ex de,hl
1291   0533 7E              ld a,(hl)
1292   0534 23              inc hl
1293   0535 ED A0           ldi
1294   0537 12              ld (de),a
1295   0538 18 C5           jr l04ffh
1296   053A             
1297   053A             ; DOWN-KEY
1298   053A             sub_053ah:
1299   053A 21 29 40        ld hl,04029h            ; E.PPC line number with cursor on (was $400A on ZX81)
1300   053D             
1301   053D             ; INC-LINE
1302   053D             l053dh:
1303   053D 5E              ld e,(hl)
1304   053E 23              inc hl
1305   053F 56              ld d,(hl)
1306   0540 E5              push hl
1307   0541 EB              ex de,hl
1308   0542 23              inc hl
1309   0543 CD 6A 0B        call sub_0b6ah
1310   0546 CD 77 06        call sub_0677h
1311   0549 E1              pop hl
1312   054A             
1313   054A             ; KEY-INPUT
1314   054A             l054ah:
1315   054A FD CB 2D 6E     bit 5,(iy+02dh)
1316   054E 20 08           jr nz,l0558h            ; routine LOWER
1317   0550 72              ld (hl),d
1318   0551 2B              dec hl
1319   0552 73              ld (hl),e
1320   0553 18 AA           jr l04ffh
1321   0555             
1322   0555             ; ----------------------------
1323   0555             ; THE 'EDIT LINE COPY' SECTION
1324   0555             ; ----------------------------
1325   0555             
1326   0555             ; EDIT-INP
1327   0555             l0555h:
1328   0555 CD A5 16        call sub_16a5h          ; CURSOR-IN, set cursor on edit line
1329   0558             
1330   0558             ; LOWER
1331   0558             l0558h:
1332   0558 2A 14 40        ld hl,(04014h)
1333   055B             
1334   055B             ; EACH-CHAR
1335   055B             l055bh:
1336   055B 7E              ld a,(hl)
1337   055C FE 7E           cp 07eh
1338   055E 20 08           jr nz,l0568h
1339   0560 01 06 00        ld bc,00006h
1340   0563 CD F5 0B        call sub_0bf5h          ; routine RECLAIM-2
1341   0566 18 F3           jr l055bh
1342   0568             
1343   0568             ; END-LINE
1344   0568             l0568h:
1345   0568 FE 76           cp 076h
1346   056A 23              inc hl
1347   056B 20 EE           jr nz,l055bh
1348   056D             
1349   056D             ; EDIT-LINE
1350   056D                 ; ZX81 sets K or L here - we don't have that
1351   056D             
1352   056D             ; EDIT-ROOM
1353   056D             l056dh:
1354   056D CD C2 0B        call sub_0bc2h          ; routine LINE-ENDS
1355   0570 2A 14 40        ld hl,(04014h)          ; Get E.LINE, the address of edit line
1356   0573 FD 36 00 FF     ld (iy+000h),0ffh       ; Set error to $FF (OK)
1357   0577 CD FC 08        call sub_08fch          ; routine COPY-LINE
1358   057A FD CB 00 7E     bit 7,(iy+000h)         ; Check if there was an error
1359   057E 20 0D           jr nz,l058dh            ; to DISPLAY-6 if OK
1360   0580 3A 22 40        ld a,(04022h)           ; check DF.SZ, size of editor section
1361   0583 FE 18           cp 018h                 ; is it >24 lines
1362   0585 30 06           jr nc,l058dh            ; to DISPLAY-6
1363   0587 3C              inc a                   ; add a line
1364   0588 32 22 40        ld (04022h),a           ; update value
1365   058B 18 E0           jr l056dh               ; simplified loop back compared to ZX81
1366   058D             
1367   058D             ; --------------------------
1368   058D             ; THE 'WAIT FOR KEY' SECTION
1369   058D             ; --------------------------
1370   058D             
1371   058D             ; DISPLAY-6
1372   058D             l058dh:
1373   058D 21 00 00        ld hl,00000h            ; clear X.PTR   - Addess of character before syntax error
1374   0590 22 18 40        ld (04018h),hl          ;
1375   0593 21 3B 40        ld hl,0403bh            ; get CDFLAGS
1376   0596 CB 7E           bit 7,(hl)              ; check FAST/SLOW mode
1377   0598 CC 93 02        call z,sub_0293h        ; routine PRE-DISPLAY-1 if FAST
1378   059B             
1379   059B             ; SLOW-DISP
1380   059B             l059bh:
1381   059B CB 46           bit 0,(hl)
1382   059D 28 FC           jr z,l059bh             ; Loop unti bit 0 of (HL) is 1
1383   059F ED 4B 25 40     ld bc,(04025h)
1384   05A3 CD 40 11        call sub_1140h          ; routine DEBOUNCE
1385   05A6 CD 5E 09        call sub_095eh          ; routine DECODE
1386   05A9 30 AD           jr nc,l0558h            ; routine LOWER
1387   05AB FD CB 3B 6E     bit 5,(iy+03bh)         ; Check if we should beep
1388   05AF 20 1D           jr nz,l05ceh
1389   05B1             
1390   05B1             ; KEY-BEEP
1391   05B1 D5              push de                 ; Save DE and HL
1392   05B2 E5              push hl
1393   05B3 CD 70 03        call sub_0370h          ; routine SET-FAST
1394   05B6 C6 14           add a,014h              ; add $14 to the key value
1395   05B8 5F              ld e,a                  ; set the note to that
1396   05B9 01 CE 04        ld bc,004ceh            ; set the duration to 18.9ms
