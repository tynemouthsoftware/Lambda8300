2455   0AAA FD CB 01 4E     bit 1,(iy+001h)
2456   0AAE 28 07           jr z,sub_0ab7h          ; routine LOC-ADDR
2457   0AB0 3E 5D           ld a,05dh
2458   0AB2 91              sub c
2459   0AB3 32 38 40        ld (04038h),a
2460   0AB6 C9              ret
2461   0AB7             
2462   0AB7             ; ----------------------------
2463   0AB7             ; THE 'LOCATE ADDRESS' ROUTINE
2464   0AB7             ; ----------------------------
2465   0AB7             
2466   0AB7             ; LOC-ADDR  different to ZX81
2467   0AB7             sub_0ab7h:
2468   0AB7 ED 43 39 40     ld (04039h),bc          ; Set S.POSN - Current PRINT position
2469   0ABB 3E 21           ld a,021h
2470   0ABD 91              sub c
2471   0ABE 4F              ld c,a
2472   0ABF 3E 18           ld a,018h
2473   0AC1 90              sub b
2474   0AC2 6F              ld l,a
2475   0AC3 26 00           ld h,000h
2476   0AC5 06 05           ld b,005h
2477   0AC7             l0ac7h:
2478   0AC7 29              add hl,hl
2479   0AC8 10 FD           djnz l0ac7h
2480   0ACA 09              add hl,bc
2481   0ACB 4F              ld c,a
2482   0ACC 09              add hl,bc
2483   0ACD 01 7E 40        ld bc,0407eh            ; position of top left character (fixed DFILE location)
2484   0AD0 09              add hl,bc               ; add offset to get address of character
2485   0AD1 22 0E 40        ld (0400eh),hl          ; Set DF.CC - Display file current character
2486   0AD4 06 00           ld b,000h
2487   0AD6 C9              ret
2488   0AD7             
2489   0AD7             ; ------------------------------
2490   0AD7             ; THE 'EXPAND TOKENS' SUBROUTINE
2491   0AD7             ; ------------------------------
2492   0AD7             
2493   0AD7             ; TOKENS
2494   0AD7             sub_0ad7h:
2495   0AD7 F5              push af
2496   0AD8 CD 07 0B        call sub_0b07h
2497   0ADB 30 08           jr nc,l0ae5h
2498   0ADD FD CB 01 46     bit 0,(iy+001h)
2499   0AE1 20 02           jr nz,l0ae5h
2500   0AE3 AF              xor a
2501   0AE4 D7              rst 10h
2502   0AE5             
2503   0AE5             ; ALL-CHARS - different to ZX81
2504   0AE5             l0ae5h:
2505   0AE5 0A              ld a,(bc)
2506   0AE6 E6 3F           and 03fh
2507   0AE8 D7              rst 10h
2508   0AE9 0A              ld a,(bc)
2509   0AEA 03              inc bc
2510   0AEB 87              add a,a
2511   0AEC 30 F7           jr nc,l0ae5h
2512   0AEE 4F              ld c,a
2513   0AEF F1              pop af
2514   0AF0 FE C0           cp 0c0h
2515   0AF2 30 03           jr nc,l0af7h
2516   0AF4 FE 43           cp 043h
2517   0AF6 D0              ret nc
2518   0AF7             l0af7h:
2519   0AF7 79              ld a,c
2520   0AF8 FE 1A           cp 01ah
2521   0AFA 28 03           jr z,l0affh
2522   0AFC FE 38           cp 038h
2523   0AFE D8              ret c
2524   0AFF             
2525   0AFF             ; TRAIL-SP
2526   0AFF             l0affh:
2527   0AFF AF              xor a
2528   0B00 FD CB 01 C6     set 0,(iy+001h)
2529   0B04 C3 96 09        jp l0996h
2530   0B07             
2531   0B07             ; TOKEN-ADD
2532   0B07             sub_0b07h:
2533   0B07 E5              push hl
2534   0B08 21 F0 00        ld hl,l00f0h            ; Tokens table
2535   0B0B CB 7F           bit 7,a
2536   0B0D 28 02           jr z,l0b11h
2537   0B0F E6 3F           and 03fh
2538   0B11             
2539   0B11             ; TEST-HIGH
2540   0B11             l0b11h:
2541   0B11 FE 46           cp 046h                 ; $46 tokens in table
2542   0B13 30 10           jr nc,l0b25h
2543   0B15 47              ld b,a
2544   0B16 04              inc b
2545   0B17             
2546   0B17             ; WORDS
2547   0B17             l0b17h:
2548   0B17 CB 7E           bit 7,(hl)
2549   0B19 23              inc hl
2550   0B1A 28 FB           jr z,l0b17h
2551   0B1C 10 F9           djnz l0b17h
2552   0B1E FE 43           cp 043h                 ; different offsets here
2553   0B20 30 03           jr nc,l0b25h
2554   0B22 FE 16           cp 016h                 ; and here
2555   0B24             
2556   0B24             ; COMP-FLAG
2557   0B24 3F              ccf
2558   0B25             
2559   0B25             ; FOUND
2560   0B25             l0b25h:
2561   0B25 44              ld b,h
2562   0B26 4D              ld c,l
2563   0B27 E1              pop hl
2564   0B28 D0              ret nc
2565   0B29 0A              ld a,(bc)
2566   0B2A C6 E4           add a,0e4h
2567   0B2C C9              ret
2568   0B2D             
2569   0B2D             ; --------------------------
2570   0B2D             ; THE 'ONE SPACE' SUBROUTINE
2571   0B2D             ; --------------------------
2572   0B2D             
2573   0B2D             ; ONE-SPACE
2574   0B2D             sub_0b2dh:
2575   0B2D 01 01 00        ld bc,00001h
2576   0B30             
2577   0B30             ; --------------------------
2578   0B30             ; THE 'MAKE ROOM' SUBROUTINE
2579   0B30             ; --------------------------
2580   0B30             
2581   0B30             ; Make room for DE bytes at HL
2582   0B30             
2583   0B30             ; MAKE-ROOM
2584   0B30             sub_0b30h:
2585   0B30 E5              push hl                 ; Save HL
2586   0B31 CD A0 10        call sub_10a0h          ; Routine TEST-ROOM
2587   0B34 E1              pop hl                  ; Restore HL
2588   0B35 CD 3F 0B        call sub_0b3fh          ; Routine POINTERS
2589   0B38 2A 1C 40        ld hl,(0401ch)          ; STKEND - End of calculator stack
2590   0B3B EB              ex de,hl                ; DE=STKEND, HL=Location of bytes to be moved, BC=number of bytes to move
2591   0B3C ED B8           lddr                    ; Move bytes
2592   0B3E C9              ret
2593   0B3F             
2594   0B3F             ; -------------------------
2595   0B3F             ; THE 'POINTERS' SUBROUTINE
2596   0B3F             ; -------------------------
2597   0B3F             
2598   0B3F             ; POINTERS
2599   0B3F             sub_0b3fh:
2600   0B3F F5              push af                 ; Save the Carry from the result of TEST-ROM
2601   0B40 E5              push hl                 ; Save HL, the destination
2602   0B41 21 0A 40        ld hl,0400ah            ; NXTLIN - Address of next line to be executed (ZX81 was $4029)
2603   0B44 3E 0A           ld a,00ah               ; Number of pointers to test
2604   0B46             
2605   0B46             ; NEXT-PTR
2606   0B46             l0b46h:
2607   0B46 5E              ld e,(hl)
2608   0B47 23              inc hl
2609   0B48 56              ld d,(hl)
2610   0B49 E3              ex (sp),hl              ; Get destination from stack
2611   0B4A A7              and a                   ; Clear carry flag
2612   0B4B ED 52           sbc hl,de               ; Subtract and restore to set flags
2613   0B4D 19              add hl,de               ;
2614   0B4E E3              ex (sp),hl              ; Restore destination to stack
2615   0B4F 30 09           jr nc,l0b5ah            ; skip to PTR-DONE if pointer below destination
2616   0B51             ; pointer is after point of insertion, so update pointer
2617   0B51 D5              push de                 ; Save DE
2618   0B52 EB              ex de,hl
2619   0B53 09              add hl,bc               ; move pointer up by BC bytes
2620   0B54 EB              ex de,hl
2621   0B55 72              ld (hl),d               ; Update the pointer
2622   0B56 2B              dec hl
2623   0B57 73              ld (hl),e
2624   0B58 23              inc hl
2625   0B59 D1              pop de                  ; Restore DE
2626   0B5A             
2627   0B5A             ; PTR-DONE
2628   0B5A             l0b5ah:
2629   0B5A 23              inc hl                  ; Next pointer
2630   0B5B 3D              dec a                   ; Reduce number of pointers left to test
2631   0B5C 20 E8           jr nz,l0b46h            ; Back to NEXT-PTR if there are more to do
2632   0B5E             
2633   0B5E             ; all pointers updated
2634   0B5E EB              ex de,hl                ; HL now contains the end of the space to add + overheads
2635   0B5F D1              pop de                  ; DE contains the location of the new space
2636   0B60 F1              pop af
2637   0B61 A7              and a
2638   0B62 ED 52           sbc hl,de               ; HL now contains the number of bytes required
2639   0B64 44              ld b,h                  ; BC=HL
2640   0B65 4D              ld c,l
2641   0B66 03              inc bc                  ; +1
2642   0B67 19              add hl,de               ; Add back
2643   0B68 EB              ex de,hl                ; Finally DE=End of space, HL=Start of space, BC=Size of space
2644   0B69 C9              ret
2645   0B6A             
2646   0B6A             ; -----------------------------
2647   0B6A             ; THE 'LINE ADDRESS' SUBROUTINE
2648   0B6A             ; -----------------------------
2649   0B6A             
2650   0B6A             ; LINE-ADDR
2651   0B6A             sub_0b6ah:
2652   0B6A E5              push hl
2653   0B6B 2A 0C 40        ld hl,(0400ch)          ; PRGRM, start of user program
2654   0B6E 54              ld d,h
2655   0B6F 5D              ld e,l
2656   0B70             
2657   0B70             ; NEXT-TEST
2658   0B70             l0b70h:
2659   0B70 C1              pop bc
2660   0B71 CD 7C 0B        call sub_0b7ch
2661   0B74 D0              ret nc
2662   0B75 C5              push bc
2663   0B76 CD 84 0B        call sub_0b84h
2664   0B79 EB              ex de,hl
2665   0B7A 18 F4           jr l0b70h
2666   0B7C             
2667   0B7C             ; -------------------------------------
2668   0B7C             ; THE 'COMPARE LINE NUMBERS' SUBROUTINE
2669   0B7C             ; -------------------------------------
2670   0B7C             
2671   0B7C             ; CP-LINES
2672   0B7C             sub_0b7ch:
2673   0B7C 7E              ld a,(hl)
2674   0B7D B8              cp b
2675   0B7E C0              ret nz
2676   0B7F 23              inc hl
2677   0B80 7E              ld a,(hl)
2678   0B81 2B              dec hl
2679   0B82 B9              cp c
2680   0B83 C9              ret
2681   0B84             
2682   0B84             ; --------------------------------------
2683   0B84             ; THE 'NEXT LINE OR VARIABLE' SUBROUTINE
2684   0B84             ; --------------------------------------
2685   0B84             
2686   0B84             ; NEXT-ONE
2687   0B84             sub_0b84h:
2688   0B84 E5              push hl
2689   0B85 7E              ld a,(hl)
2690   0B86 FE 40           cp 040h
2691   0B88 38 17           jr c,l0ba1h
2692   0B8A CB 6F           bit 5,a
2693   0B8C 28 14           jr z,l0ba2h
2694   0B8E 87              add a,a
2695   0B8F FA 93 0B        jp m,l0b93h
2696   0B92 3F              ccf
2697   0B93             
2698   0B93             ; NEXT+FIVE
2699   0B93             l0b93h:
2700   0B93 01 05 00        ld bc,00005h
2701   0B96 30 02           jr nc,l0b9ah
2702   0B98 0E 11           ld c,011h
2703   0B9A             
2704   0B9A             ; NEXT-LETT
2705   0B9A             l0b9ah:
2706   0B9A 17              rla
2707   0B9B 23              inc hl
2708   0B9C 7E              ld a,(hl)
2709   0B9D 30 FB           jr nc,l0b9ah
2710   0B9F 18 06           jr l0ba7h
2711   0BA1             
2712   0BA1             ; LINES
2713   0BA1             l0ba1h:
2714   0BA1 23              inc hl
2715   0BA2             
2716   0BA2             ; NEXT-O-4
2717   0BA2             l0ba2h:
2718   0BA2 23              inc hl
2719   0BA3 4E              ld c,(hl)
2720   0BA4 23              inc hl
2721   0BA5 46              ld b,(hl)
2722   0BA6 23              inc hl
2723   0BA7             
2724   0BA7             ; NEXT-ADD
2725   0BA7             l0ba7h:
2726   0BA7 09              add hl,bc
2727   0BA8 D1              pop de
2728   0BA9             
2729   0BA9             ; ---------------------------
2730   0BA9             ; THE 'DIFFERENCE' SUBROUTINE
2731   0BA9             ; ---------------------------
2732   0BA9             
2733   0BA9             ; DIFFER
2734   0BA9             sub_0ba9h:
2735   0BA9 A7              and a
2736   0BAA ED 52           sbc hl,de
2737   0BAC 44              ld b,h
2738   0BAD 4D              ld c,l
2739   0BAE 19              add hl,de
2740   0BAF EB              ex de,hl
2741   0BB0 C9              ret
2742   0BB1             
2743   0BB1             ; -------------------------------
2744   0BB1             ; THE 'SCROLL COMMAND' SUBROUTINE
2745   0BB1             ; -------------------------------
2746   0BB1             
2747   0BB1             ; scrolling is easy with a fully expanded DFILE
2748   0BB1             ; copy lines 2-24 to 1-23
2749   0BB1             
2750   0BB1             ; SCROLL
2751   0BB1             sub_0bb1h:
2752   0BB1 21 9F 40        ld hl,DFILE+022h        ; Source, start of line 2
2753   0BB4 11 7E 40        ld de,DFILE+1           ; Destination, start of line 1
2754   0BB7 01 F6 02        ld bc,l02f6h            ; 23*33-1, 23 lines to copy
2755   0BBA ED B0           ldir                    ; copy
2756   0BBC FD 46 22        ld b,(iy+022h)          ; get DF.SZ - Size of editor part of screen
2757   0BBF 04              inc b                   ; increase by 1 row
2758   0BC0 18 10           jr l0bd2h               ; routine B-LINES, clear the editor lines
2759   0BC2             
2760   0BC2             ; --------------------------
2761   0BC2             ; THE 'LINE-ENDS' SUBROUTINE
2762   0BC2             ; --------------------------
2763   0BC2             
2764   0BC2             ; LINE-ENDS
2765   0BC2             sub_0bc2h:
2766   0BC2 FD 46 22        ld b,(iy+022h)
2767   0BC5 C5              push bc
2768   0BC6 CD D2 0B        call l0bd2h
2769   0BC9 C1              pop bc
2770   0BCA 05              dec b
2771   0BCB 0E 21           ld c,021h
2772   0BCD C3 B7 0A        jp sub_0ab7h            ; routine LOC-ADDR
2773   0BD0             
2774   0BD0             ; -------------------------
2775   0BD0             ; THE 'CLS' COMMAND ROUTINE
2776   0BD0             ; -------------------------
2777   0BD0             
2778   0BD0             ; Different as there is no collapsed display file
2779   0BD0             
2780   0BD0             ; CLS
2781   0BD0             sub_0bd0h:
2782   0BD0 06 18           ld b,018h               ; 24 lines
2783   0BD2             
2784   0BD2             ; B-LINES
2785   0BD2             l0bd2h:
2786   0BD2 FD CB 01 8E     res 1,(iy+001h)         ; Clear FLAG - printer not in use
2787   0BD6 FD 36 7C 00     ld (iy+07ch),000h       ; Clear address of blinking curosr
2788   0BDA FD CB 01 C6     set 0,(iy+001h)         ; Set FLAG  - Suppress leading space
2789   0BDE 0E 21           ld c,021h
2790   0BE0 C5              push bc
2791   0BE1 CD B7 0A        call sub_0ab7h          ; routine LOC-ADDR
2792   0BE4 C1              pop bc
2793   0BE5 48              ld c,b
2794   0BE6             
2795   0BE6             ; CLEAR-SCREEN
2796   0BE6 AF              xor a                   ; A = 0 = SPACE
2797   0BE7             l0be7h:
2798   0BE7 06 20           ld b,020h               ; 32 characters
2799   0BE9             l0be9h:
2800   0BE9 77              ld (hl),a               ; clear character
2801   0BEA 23              inc hl
2802   0BEB 10 FC           djnz l0be9h             ; loop until EOL
2803   0BED 23              inc hl                  ; skip over NEWLINE
2804   0BEE 0D              dec c                   ; line counter
2805   0BEF 20 F6           jr nz,l0be7h            ; loop back until complete
2806   0BF1 C9              ret
2807   0BF2             
2808   0BF2             ; ----------------------------
2809   0BF2             ; THE 'RECLAIMING' SUBROUTINES
2810   0BF2             ; ----------------------------
2811   0BF2             
2812   0BF2             ; RECLAIM-1
2813   0BF2             sub_0bf2h:
2814   0BF2 CD A9 0B        call sub_0ba9h
2815   0BF5             
2816   0BF5             ; RECLAIM-2
2817   0BF5             sub_0bf5h:
2818   0BF5 C5              push bc
2819   0BF6 78              ld a,b
2820   0BF7 2F              cpl
2821   0BF8 47              ld b,a
2822   0BF9 79              ld a,c
2823   0BFA 2F              cpl
2824   0BFB 4F              ld c,a
2825   0BFC 03              inc bc
2826   0BFD CD 3F 0B        call sub_0b3fh
2827   0C00 EB              ex de,hl
2828   0C01 E1              pop hl
2829   0C02 19              add hl,de
2830   0C03 D5              push de
2831   0C04 ED B0           ldir
2832   0C06 E1              pop hl
2833   0C07 C9              ret
2834   0C08             
2835   0C08             ; ------------------------------
2836   0C08             ; THE 'E-LINE NUMBER' SUBROUTINE
2837   0C08             ; ------------------------------
2838   0C08             
2839   0C08             ; E-LINE-NO
2840   0C08             sub_0c08h:
2841   0C08 2A 14 40        ld hl,(04014h)
2842   0C0B CD 4E 00        call sub_004eh
2843   0C0E DF              rst 18h
2844   0C0F             ;sub_0c0fh:
2845   0C0F FD CB 2D 6E     bit 5,(iy+02dh)
2846   0C13 C0              ret nz
2847   0C14 21 5D 40        ld hl,0405dh
2848   0C17 22 1C 40        ld (0401ch),hl
2849   0C1A CD 40 17        call sub_1740h
2850   0C1D CD 82 17        call sub_1782h
2851   0C20 38 04           jr c,l0c26h
2852   0C22 21 F0 D8        ld hl,0d8f0h
2853   0C25 09              add hl,bc
2854   0C26             
2855   0C26             ; NO-NUMBER
2856   0C26             l0c26h:
2857   0C26 DA 17 0F        jp c,l0f17h             ; to REPORT-C - Invalid Expression
2858   0C29 BF              cp a
2859   0C2A C3 B4 16        jp l16b4h
2860   0C2D             
2861   0C2D             ; -------------------------------------------------
2862   0C2D             ; THE 'REPORT AND LINE NUMBER' PRINTING SUBROUTINES
2863   0C2D             ; -------------------------------------------------
2864   0C2D             
2865   0C2D             ; OUT-NUM
2866   0C2D             sub_0c2dh:
2867   0C2D D5              push de
2868   0C2E E5              push hl
2869   0C2F                 ; missing call to UNITS here
2870   0C2F 60              ld h,b
2871   0C30 69              ld l,c
2872   0C31 1E FF           ld e,0ffh
2873   0C33 18 08           jr l0c3dh
2874   0C35             
2875   0C35             ; OUT-NO
2876   0C35             sub_0c35h:
2877   0C35 D5              push de
2878   0C36 56              ld d,(hl)
2879   0C37 23              inc hl
2880   0C38 5E              ld e,(hl)
2881   0C39 E5              push hl
2882   0C3A EB              ex de,hl
2883   0C3B 1E 00           ld e,000h
2884   0C3D             
2885   0C3D             ; THOUSAND
2886   0C3D             l0c3dh:
2887   0C3D 01 18 FC        ld bc,0fc18h
2888   0C40 CD 82 09        call sub_0982h
2889   0C43 01 9C FF        ld bc,0ff9ch
2890   0C46 CD 82 09        call sub_0982h
2891   0C49 0E F6           ld c,0f6h
2892   0C4B CD 82 09        call sub_0982h
2893   0C4E 7D              ld a,l
2894   0C4F             
2895   0C4F             ; UNITS
2896   0C4F CD 8C 09        call sub_098ch
2897   0C52 E1              pop hl
2898   0C53 D1              pop de
2899   0C54 C9              ret
2900   0C55             
2901   0C55             ; --------------------------
2902   0C55             ; THE 'UNSTACK-Z' SUBROUTINE
2903   0C55             ; --------------------------
2904   0C55             
2905   0C55             ; UNSTACK-Z
2906   0C55             sub_0c55h:
2907   0C55 CD 23 0F        call sub_0f23h
2908   0C58 E1              pop hl
2909   0C59 C8              ret z
2910   0C5A E9              jp (hl)
2911   0C5B             
2912   0C5B             ; ----------------------------
2913   0C5B             ; THE 'LPRINT' COMMAND ROUTINE
2914   0C5B             ; ----------------------------
2915   0C5B             
2916   0C5B             ; LPRINT
2917   0C5B             sub_0c5bh:
2918   0C5B FD CB 01 CE     set 1,(iy+001h)
2919   0C5F             
2920   0C5F             ; ---------------------------
2921   0C5F             ; THE 'PRINT' COMMAND ROUTINE
2922   0C5F             ; ---------------------------
2923   0C5F             
2924   0C5F             ; PRINT
2925   0C5F             sub_0c5fh:
2926   0C5F 7E              ld a,(hl)
2927   0C60 FE 76           cp 076h
2928   0C62 CA 0B 0D        jp z,l0d0bh
2929   0C65             
2930   0C65             ; PRINT-1
2931   0C65             l0c65h:
2932   0C65 D6 1A           sub 01ah
2933   0C67 CE 00           adc a,000h
2934   0C69 28 66           jr z,l0cd1h
2935   0C6B FE BA           cp 0bah
2936   0C6D 20 1B           jr nz,l0c8ah
2937   0C6F E7              rst 20h
2938   0C70 CD 0F 0F        call sub_0f0fh
2939   0C73 FE 1A           cp 01ah
2940   0C75 C2 17 0F        jp nz,l0f17h            ; to REPORT-C - Invalid Expression
2941   0C78 E7              rst 20h
2942   0C79 CD 0F 0F        call sub_0f0fh
2943   0C7C CD DB 0C        call sub_0cdbh
2944   0C7F EF              rst 28h                 ; FP-CALC
2945   0C80 01              .byte $01               ;;exchange
2946   0C81 34              .byte $34               ;;end-calc
2947   0C82 CD 7A 0D        call sub_0d7ah
2948   0C85 CD 94 0A        call sub_0a94h
2949   0C88 18 3A           jr l0cc4h
2950   0C8A             
2951   0C8A             ; NOT-AT
2952   0C8A             l0c8ah:
2953   0C8A FE BB           cp 0bbh                 ; different token on ZX81
2954   0C8C 20 30           jr nz,l0cbeh
2955   0C8E E7              rst 20h
2956   0C8F CD 0F 0F        call sub_0f0fh
2957   0C92 CD DB 0C        call sub_0cdbh
2958   0C95 CD 83 10        call sub_1083h
